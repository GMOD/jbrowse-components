{
  "name": "@jbrowse/plugin-data-management",
  "version": "4.3.0",
  "type": "module",
  "description": "JBrowse 2 linear genome view",
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "license": "Apache-2.0",
  "homepage": "https://jbrowse.org",
  "bugs": "https://github.com/GMOD/jbrowse-components/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-components.git",
    "directory": "plugins/data-management"
  },
  "author": "JBrowse Team",
  "main": "src/index.ts",
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "pnpm run /^build:/",
    "test": "cd ../..; jest --passWithNoTests plugins/data-management",
    "prepublishOnly": "pnpm test",
    "prepack": "pnpm build",
    "prebuild": "pnpm clean",
    "build:esm": "tsgo --build tsconfig.build.esm.json",
    "clean": "rimraf esm *.tsbuildinfo"
  },
  "dependencies": {
    "@gmod/ucsc-hub": "^2.0.11",
    "@jbrowse/core": "workspace:^",
    "@jbrowse/mobx-state-tree": "^5.11.2",
    "@jbrowse/plugin-config": "workspace:^",
    "@jbrowse/product-core": "workspace:^",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@mui/x-data-grid": "^9.7.0",
    "deepmerge": "^4.3.1",
    "mobx": "^6.16.1",
    "mobx-react": "^9.2.2"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "esm/index.js",
    "types": "esm/index.d.ts",
    "exports": {
      ".": {
        "types": "./esm/index.d.ts",
        "import": "./esm/index.js"
      }
    }
  },
  "sideEffects": false,
  "devDependencies": {
    "@jbrowse/app-core": "workspace:*",
    "@jbrowse/plugin-alignments": "workspace:^",
    "@jbrowse/plugin-hic": "workspace:^",
    "@jbrowse/plugin-variants": "workspace:^"
  }
}
