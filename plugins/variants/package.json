{
  "name": "@jbrowse/plugin-variants",
  "version": "4.3.0",
  "type": "module",
  "description": "JBrowse 2 variant adapters, tracks, etc.",
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "license": "Apache-2.0",
  "homepage": "https://jbrowse.org",
  "bugs": "https://github.com/GMOD/jbrowse-components/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-components.git",
    "directory": "plugins/variants"
  },
  "author": "JBrowse Team",
  "main": "src/index.ts",
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "pnpm run /^build:/",
    "test": "cd ../..; jest --passWithNoTests plugins/variants",
    "prepublishOnly": "pnpm test",
    "prepack": "pnpm build",
    "prebuild": "pnpm clean",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "clean": "rimraf esm *.tsbuildinfo"
  },
  "dependencies": {
    "@gmod/hclust": "3.0.14",
    "@gmod/tabix": "^3.3.9",
    "@gmod/vcf": "^7.0.9",
    "@jbrowse/core": "workspace:^",
    "@jbrowse/ld-core": "workspace:^",
    "@jbrowse/mobx-state-tree": "^5.11.0",
    "@jbrowse/plugin-canvas": "workspace:^",
    "@jbrowse/plugin-linear-genome-view": "workspace:^",
    "@jbrowse/sv-core": "workspace:^",
    "@jbrowse/tree-sidebar": "workspace:^",
    "@jbrowse/wiggle-core": "workspace:^",
    "@mui/icons-material": "^9.1.0",
    "@mui/material": "^9.1.0",
    "@mui/x-data-grid": "^9.4.0",
    "fast-deep-equal": "^3.1.3",
    "mobx": "^6.16.1",
    "mobx-react": "^9.2.2",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "esm/index.js",
    "types": "esm/index.d.ts",
    "exports": {
      ".": {
        "types": "./esm/index.d.ts",
        "import": "./esm/index.js"
      }
    }
  },
  "sideEffects": false
}
