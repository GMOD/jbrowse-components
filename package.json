{
  "name": "root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "repository": "https://github.com/GMOD/jbrowse-components",
  "workspaces": [
    "packages/*",
    "products/*",
    "plugins/*"
  ],
  "scripts": {
    "postinstall": "node products/jbrowse-web/scripts/genBuildInfo.ts",
    "build": "pnpm -r build",
    "build:esm": "node node_modules/typescript7/bin/tsc --build tsconfig.build.json",
    "gen-tsconfig-refs": "node --experimental-strip-types scripts/generate-tsconfig-references.ts",
    "check-declaration-leaks": "node --experimental-strip-types scripts/check-declaration-leaks.ts",
    "changelog": "scripts/generate-changelog.sh",
    "lint": "oxlint --type-aware --deny-warnings",
    "lint:fast": "oxlint --deny-warnings",
    "lint:eslint": "eslint --max-warnings 0",
    "format": "oxfmt . && prettier --write \"**/*.astro\"",
    "check-format": "oxfmt --check . && prettier --check \"**/*.astro\"",
    "typecheck": "node node_modules/typescript7/bin/tsc --noEmit",
    "test-ci": "NODE_OPTIONS='--max-old-space-size=7000' jest --ci",
    "built-test-ci": "jest --ci integration.test.js",
    "test": "jest",
    "gendocs": "rm -rf website/docs/config website/docs/models website/docs/api && node docs/generate.ts && oxfmt website/docs/config website/docs/models website/docs/api website/docs/developer_guides website/docs/config_guides",
    "gen-adr-index": "node website/scripts/generate-adr-index.ts",
    "gen-img-doc": "node website/scripts/generate-img-doc.ts",
    "gen-cli-doc": "node website/scripts/generate-cli-doc.ts",
    "autogen": "pnpm gendocs && pnpm gen-img-doc && pnpm gen-cli-doc",
    "postautogen": "pnpm format",
    "gen:shaders": "node packages/shader-tools/src/build-shaders.ts",
    "sync-doc-snippets": "node website/scripts/sync-doc-snippets.ts",
    "lint-docs": "node website/scripts/generate-guide-indexes.ts && pnpm gen-adr-index",
    "lint-docs-check": "node website/scripts/sync-doc-snippets.ts --check && node website/scripts/generate-guide-indexes.ts --check && pnpm gen-adr-index --check && pnpm gen-img-doc --check && pnpm gen-cli-doc --check && node website/scripts/check-doc-imports.ts",
    "fix-extensions": "node scripts/add-extensions.ts",
    "release": "node scripts/release.ts",
    "releasenotes": "node scripts/releasenotes.ts",
    "announce": "node scripts/announce.ts",
    "announce:dispatch": "gh workflow run announce.yml",
    "test:browser": "pnpm --filter @jbrowse/web build && node products/jbrowse-web/browser-tests/runner.ts",
    "test:browser:headed": "pnpm --filter @jbrowse/web build && node products/jbrowse-web/browser-tests/runner.ts --headed",
    "test:browser:update": "pnpm --filter @jbrowse/web build && node products/jbrowse-web/browser-tests/runner.ts --update-snapshots",
    "test:browser:webgl": "pnpm --filter @jbrowse/web build && node products/jbrowse-web/browser-tests/runner.ts --backend=webgl",
    "test:browser:compare": "pnpm --filter @jbrowse/web build && node products/jbrowse-web/browser-tests/compare-backends.ts",
    "test:e2e:desktop": "pnpm --filter @jbrowse/desktop test:e2e"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@electron/notarize": "^3.1.1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint-react/eslint-plugin": "^5.17.3",
    "@eslint/js": "^10.0.1",
    "@jbrowse/mobx-state-tree": "^5.13.0",
    "@jbrowse/web": "workspace:^",
    "@mui/material": "^9.2.0",
    "@mui/system": "^9.2.0",
    "@mui/x-data-grid": "^9.10.0",
    "@r2wc/react-to-web-component": "^2.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cli-progress": "^3.11.6",
    "@types/cors": "^2.8.19",
    "@types/cross-spawn": "^6.0.6",
    "@types/d3-array": "^3.2.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-scale": "^4.0.9",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jest-image-snapshot": "^6.4.1",
    "@types/node": "^26.1.1",
    "@types/pluralize": "^0.0.33",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/serve-handler": "^6.1.4",
    "@types/tmp": "^0.2.6",
    "@webgpu/types": "^0.1.71",
    "babel-loader": "^10.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "browserslist": "^4.28.6",
    "canvas": "^3.2.3",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "cross-spawn": "^7.0.6",
    "css-loader": "^7.1.4",
    "electron": "^43.1.1",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-astro": "3.0.0",
    "eslint-plugin-baseline-js": "^0.7.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-tss-unused-classes": "^1.0.4",
    "eslint-plugin-unicorn": "72.0.0",
    "express": "^5.2.1",
    "generic-filehandle2": "^2.2.0",
    "globals": "^17.7.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-fetch-mock": "^4.2.0",
    "jest-image-snapshot": "^6.5.2",
    "mini-css-extract-plugin": "^2.10.2",
    "mobx": "^6.16.1",
    "mobx-react": "^9.2.2",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "puppeteer": "^25.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-refresh": "^0.18.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "serve-handler": "^6.1.7",
    "slugify": "^1.6.9",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "typescript7": "npm:typescript@^7.0.2",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
  },
  "version": "0.0.0"
}
