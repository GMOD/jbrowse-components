{
  "name": "@jbrowse/website-astro",
  "type": "module",
  "scripts": {
    "dev": "rimraf .astro && astro dev",
    "build": "astro build && pagefind --site dist",
    "index": "astro build && pagefind --site dist --output-path static/pagefind",
    "preview": "astro preview",
    "lint-docs": "node --experimental-strip-types scripts/generate-guide-indexes.ts",
    "lint-docs-check": "node --experimental-strip-types scripts/generate-guide-indexes.ts --check",
    "generate-screenshots": "node --experimental-strip-types scripts/generate-screenshots.ts",
    "review-screenshots": "node --experimental-strip-types scripts/review-screenshots.ts",
    "review-screenshots-web": "node --experimental-strip-types scripts/review-screenshots-web.ts"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "astro": "^6.4.4",
    "astro-icon": "^1.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "pagefind": "^1.5.2",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3"
  }
}
