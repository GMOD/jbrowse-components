{
  "name": "@jbrowse/website",
  "license": "Apache-2.0",
  "homepage": ".",
  "scripts": {
    "prep": "cp ../products/jbrowse-cli/README.md docs/cli.md && pnpm fetchPlugins",
    "fetchPlugins": "rimraf plugins.json && wget -q https://s3.amazonaws.com/jbrowse.org/plugin-store/plugins.json",
    "prebuild": "pnpm prep",
    "prestart": "pnpm prep",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "typecheck": "tsc",
    "predeploy": "pnpm build",
    "deploy": "aws s3 sync --delete build s3://jbrowse.org/jb2/",
    "postdeploy": "aws cloudfront create-invalidation --distribution-id E13LGELJOT4GQO --paths \"/jb2/*\""
  },
  "dependencies": {
    "@cmfcmf/docusaurus-search-local": "^2.0.1",
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/faster": "^3.10.0",
    "@docusaurus/plugin-google-gtag": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-classic": "^3.10.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mdx-js/react": "^3.1.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@tsconfig/docusaurus": "^2.0.9",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
