{
  "name": "@jbrowse/website-astro",
  "type": "module",
  "scripts": {
    "dev": "rimraf .astro && astro dev",
    "build": "astro build && pagefind --site dist",
    "index": "astro build && pagefind --site dist --output-path static/pagefind",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint-docs": "node scripts/generate-guide-indexes.ts",
    "lint-docs-check": "node scripts/generate-guide-indexes.ts --check",
    "check-doc-imports": "node scripts/check-doc-imports.ts",
    "check-sidebar": "node scripts/check-sidebar.ts",
    "check-links": "node scripts/check-links.ts",
    "check-llms": "node scripts/check-llms.ts",
    "snapshot": "node scripts/snapshot.ts",
    "screenshots": "node scripts/generate-screenshots.ts",
    "screenshots:build": "pnpm --filter @jbrowse/web build && pnpm --filter @jbrowse/react-linear-genome-view2 build:webpack && node scripts/generate-screenshots.ts",
    "check-spec-recipes": "node scripts/check-spec-recipes.ts",
    "gen:gallery-links": "node scripts/gen-gallery-links.ts",
    "gen:gallery-links-check": "node scripts/gen-gallery-links.ts --check",
    "gen:tutorial-thumbs": "node scripts/gen-tutorial-thumbs.ts",
    "gen:tutorial-thumbs-check": "node scripts/gen-tutorial-thumbs.ts --check",
    "gen:home-images": "node scripts/gen-home-images.ts",
    "gen:home-images-check": "node scripts/gen-home-images.ts --check",
    "review-screenshots-web": "node scripts/review-screenshots-web.ts",
    "audit-figures": "node scripts/audit-figures.ts"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "astro": "^7.1.3",
    "astro-icon": "^1.1.5",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.35.3",
    "shiki": "^4.3.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@iconify-json/mdi": "^1.2.3",
    "@jbrowse/browser-test-utils": "workspace:*",
    "@types/hast": "^3.0.5",
    "@types/mdast": "^4.0.4",
    "pagefind": "^1.5.2",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
