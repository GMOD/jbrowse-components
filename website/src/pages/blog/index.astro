---
import { getCollection } from 'astro:content'

import BlogLayout from '../../layouts/BlogLayout.astro'
import { baseUrl } from '../../lib/base-url.ts'
import { blogPath } from '../../lib/blog-path.ts'
import { renderMarkdown } from '../../lib/markdown.ts'
import blog from '../../styles/blog.module.css'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)

const renderedPosts = await Promise.all(
  posts.slice(0, 10).map(async post => {
    const { html } = await renderMarkdown(post.body ?? '')
    return { post, html }
  }),
)
---

<BlogLayout
  title="JBrowse Blog"
  description="Release announcements and news from the JBrowse project."
>
  <div class="content">
    {
      renderedPosts.map(({ post, html }) => (
        <article>
          <header>
            <h2>
              <a href={`${baseUrl}/blog/${blogPath(post)}/`}>
                {post.data.title}
              </a>
            </h2>
            <div class="article-meta">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              {post.data.author && (
                <span class="author">{post.data.author}</span>
              )}
              {post.data.tags && (
                <div class={blog.tags}>
                  {post.data.tags.map(tag => (
                    <span class={blog.tag}>{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </header>
          <div class:list={['post-body', blog.prose]}>
            <Fragment set:html={html} />
          </div>
        </article>
      ))
    }
  </div>
</BlogLayout>

<style>
  .content {
    max-width: 800px;
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2.5rem);
  }
  article {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  article header {
    margin-bottom: 1rem;
  }
  article h2 {
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.4rem;
  }
  article h2 a {
    color: var(--color-accent);
    text-decoration: none;
  }
  article h2 a:hover {
    text-decoration: underline;
  }
  .article-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .author {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .post-body {
    line-height: 1.7;
    overflow-wrap: break-word;
  }
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    font-weight: 500;
    margin: 1.5rem 0 0.5rem;
  }
  .post-body :global(h2) {
    font-size: 1.25rem;
  }
  .post-body :global(h3) {
    font-size: 1.1rem;
  }
</style>
