---
import { getCollection } from 'astro:content'

import DocsLayout from '../../../layouts/DocsLayout.astro'
import { baseUrl } from '../../../lib/base-url.ts'
import { entrySlug } from '../../../lib/docs-sidebar.ts'

// Section order for the landing page. A tutorial declares its section via the
// `tutorial_category` frontmatter field; anything missing or unlisted falls
// into a trailing "More tutorials" bucket, so a new tutorial always appears
// even before it is categorized.
const CATEGORY_ORDER = new Set([
  'Getting started',
  'Synteny & comparative genomics',
  'Structural variation',
  'Population genomics',
  'Epigenomics & single cell',
  'Transcriptomics & proteins',
])
const FALLBACK = 'More tutorials'

const tutorials = (await getCollection('docs'))
  .filter(entry => entry.id.startsWith('tutorials/'))
  .map(entry => ({
    href: `${baseUrl}/docs/${entrySlug(entry.id)}/`,
    title: entry.data.title,
    description: entry.data.description,
    category: entry.data.tutorial_category ?? FALLBACK,
  }))
  .sort((a, b) => a.title.localeCompare(b.title))

const grouped = [...CATEGORY_ORDER, FALLBACK]
  .map(category => ({
    category,
    items: tutorials.filter(t =>
      CATEGORY_ORDER.has(t.category)
        ? t.category === category
        : category === FALLBACK,
    ),
  }))
  .filter(group => group.items.length > 0)
---

<DocsLayout
  title="Tutorials"
  currentSlug="tutorials"
  description="Step-by-step, data-driven walkthroughs of common JBrowse workflows."
>
  <p class="lead">
    Hands-on walkthroughs of common JBrowse workflows, each built around a real
    dataset.
  </p>
  {
    grouped.map(group => (
      <section class="tut-section">
        <h2 class="tut-heading">{group.category}</h2>
        <ul class="tut-list">
          {group.items.map(tutorial => (
            <li>
              <a href={tutorial.href}>{tutorial.title}</a>
              {tutorial.description && <> — {tutorial.description}</>}
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</DocsLayout>

<style>
  .lead {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }
  .tut-section {
    margin: 0 0 1.75rem;
  }
  .tut-heading {
    font-size: 1.15rem;
    margin: 0 0 0.6rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border);
  }
  .tut-list {
    margin: 0;
    padding-left: 1.25rem;
  }
  .tut-list li {
    margin: 0.35rem 0;
    line-height: 1.5;
    color: var(--color-text-muted);
  }
</style>
