---
import { getCollection } from 'astro:content'

import DocsLayout from '../../../layouts/DocsLayout.astro'
import { baseUrl } from '../../../lib/base-url.ts'
import { entrySlug } from '../../../lib/docs-sidebar.ts'

// Section order for the landing page. A tutorial declares its section via the
// `tutorial_category` frontmatter field; anything missing or unlisted falls
// into a trailing "More tutorials" bucket, so a new tutorial always appears
// even before it is categorized.
const CATEGORY_ORDER = new Set([
  'Getting started',
  'Synteny & comparative genomics',
  'Structural variation',
  'Population genomics',
  'Epigenomics & single cell',
  'Transcriptomics & proteins',
  'Configuration & embedding',
])
const FALLBACK = 'More tutorials'

// Some docs live outside tutorials/ but belong on this landing page: the
// quickstarts are, in practice, the first tutorials a new user follows, and the
// cookbook is a natural companion to the configuration walkthroughs. Map each to
// the section it should appear in.
const EXTRA_DOCS = new Map([
  ['quickstart_web', 'Getting started'],
  ['quickstart_desktop', 'Getting started'],
  ['cookbook', 'Configuration & embedding'],
])

// Curated order within each section. Sorting alphabetically floated niche pages
// to the top (the CLI config walkthrough once led Getting started); instead lead
// with the most representative / beginner-friendly page. Getting started is just
// the two quickstarts; the domain analysis sections follow; and the more
// advanced, developer/admin-oriented configuration work (display defaults,
// embedding, CLI-config walkthroughs) sits last in its own Configuration &
// embedding section. Anything unlisted falls after, alphabetically.
const ORDER = [
  'quickstart_web',
  'quickstart_desktop',
  'synteny_visualization',
  'multiway_synteny',
  'allvsall_synteny',
  'pangenome_ecoli',
  'pangenome_cactus',
  'pangenome_hprc',
  'sv_visualization_cgiab',
  'sv_multisamples',
  'population_genomics',
  'analyze_trio',
  'linkage_disequilibrium',
  'bxd_qtl',
  'methylation',
  'bisulfite',
  'chromhmm',
  'scatac_pseudobulk',
  'rnaseq',
  'protein_structure',
  'cookbook',
  'display_settings',
  'embed_linear_genome_view',
  'embedding_examples',
  'cli_desktop',
]
const rank = (key: string) => {
  const i = ORDER.indexOf(key)
  return i === -1 ? ORDER.length : i
}

// A doc id ("tutorials/rnaseq", "quickstart_web") maps to a thumbnail at
// static/img/tutorial-thumbs/<key>.webp illustrating what the page produces. A
// page with no thumbnail (e.g. the text-only CLI walkthrough) renders a compact
// chromeless card instead.
const key = (id: string) =>
  id.startsWith('tutorials/') ? id.slice('tutorials/'.length) : id

const docs = await getCollection('docs')
const cardFrom = (entry: (typeof docs)[number], category: string) => ({
  key: key(entry.id),
  href: `${baseUrl}/docs/${entrySlug(entry.id)}/`,
  title: entry.data.title,
  description: entry.data.description,
  category,
  external: false,
})

// Live example sites linked straight from the section, so readers who want to
// embed can jump to runnable examples rather than only the prose tutorial. Its
// thumbnail is a capture of the examples site itself.
const EXTERNAL_CARDS = [
  {
    key: 'embedding_examples',
    href: 'https://jbrowse.org/storybook/lgv/',
    title: 'Embedded component examples',
    description:
      'Live, copy-paste examples for the embeddable React components: themes, per-feature colors, sessions, text search, and more.',
    category: 'Configuration & embedding',
    external: true,
  },
]

const tutorials = [
  ...docs
    .filter(entry => EXTRA_DOCS.has(entry.id))
    .map(entry => cardFrom(entry, EXTRA_DOCS.get(entry.id)!)),
  ...docs
    .filter(entry => entry.id.startsWith('tutorials/'))
    .map(entry => cardFrom(entry, entry.data.tutorial_category ?? FALLBACK)),
  ...EXTERNAL_CARDS,
].sort((a, b) => rank(a.key) - rank(b.key) || a.title.localeCompare(b.title))

// A mistyped tutorial_category isn't a visible typo — it silently drops the page
// into the FALLBACK bucket. Fail the build instead so the frontmatter and
// CATEGORY_ORDER can't drift apart. Tutorials with no category are fine; they
// intentionally fall through to FALLBACK.
const miscategorized = docs
  .filter(entry => entry.id.startsWith('tutorials/'))
  .filter(
    entry =>
      entry.data.tutorial_category &&
      !CATEGORY_ORDER.has(entry.data.tutorial_category),
  )
  .map(entry => `${entry.id}: "${entry.data.tutorial_category}"`)
if (miscategorized.length > 0) {
  throw new Error(
    `Unknown tutorial_category (add it to CATEGORY_ORDER or fix the typo):\n  ${miscategorized.join('\n  ')}`,
  )
}

const grouped = [...CATEGORY_ORDER, FALLBACK]
  .map(category => ({
    category,
    items: tutorials.filter(t =>
      CATEGORY_ORDER.has(t.category)
        ? t.category === category
        : category === FALLBACK,
    ),
  }))
  .filter(group => group.items.length > 0)

// Pages with no generated thumbnail render a compact chromeless card instead of
// a broken image. Only the text-only CLI walkthrough has none; every other
// tutorial has a thumb under static/img/tutorial-thumbs/ (managed ones in
// gen-tutorial-thumbs.ts).
const NO_THUMB = new Set(['cli_desktop'])
const HAS_THUMB = new Set(
  tutorials.map(t => t.key).filter(k => !NO_THUMB.has(k)),
)
---

<DocsLayout
  title="Tutorials"
  currentSlug="tutorials"
  description="Step-by-step, data-driven walkthroughs of common JBrowse workflows."
>
  <p class="lead">
    Hands-on walkthroughs of common JBrowse workflows, from first setup to
    advanced analysis.
  </p>
  {
    grouped.map(group => (
      <section class="tut-section">
        <h2 class="tut-heading">{group.category}</h2>
        <div class="tut-grid">
          {group.items.map(tutorial => (
            <a
              class="tut-card"
              href={tutorial.href}
              target={tutorial.external ? '_blank' : undefined}
              rel={tutorial.external ? 'noopener' : undefined}
            >
              {HAS_THUMB.has(tutorial.key) ? (
                <img
                  class="tut-thumb"
                  src={`${baseUrl}/img/tutorial-thumbs/${tutorial.key}.webp`}
                  loading="lazy"
                  decoding="async"
                  alt={`Preview of ${tutorial.title}`}
                />
              ) : (
                <span class="tut-thumb tut-thumb-empty">
                  {tutorial.key === 'cli_desktop' ? '$ jbrowse' : 'JBrowse 2'}
                </span>
              )}
              <span class="tut-card-body">
                <span class="tut-card-title">
                  {tutorial.title}
                  {tutorial.external && <span class="tut-ext"> ↗</span>}
                </span>
                {tutorial.description && (
                  <span class="tut-card-desc">{tutorial.description}</span>
                )}
              </span>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</DocsLayout>

<style>
  .lead {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }
  .tut-section {
    margin: 0 0 2rem;
  }
  .tut-heading {
    font-size: 1.15rem;
    margin: 0 0 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border);
  }
  .tut-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 1rem;
  }
  .tut-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease,
      transform 0.15s ease;
  }
  .tut-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }
  .tut-thumb {
    width: 100%;
    aspect-ratio: 5 / 3;
    object-fit: cover;
    object-position: top;
    display: block;
    border-bottom: 1px solid var(--color-border);
    background: #fff;
  }
  .tut-thumb-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    background: var(--color-blockquote-bg);
  }
  .tut-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.7rem 0.8rem 0.85rem;
  }
  .tut-card-title {
    font-weight: 600;
    line-height: 1.3;
  }
  .tut-ext {
    color: var(--color-text-muted);
    font-weight: 400;
  }
  .tut-card-desc {
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }
</style>
