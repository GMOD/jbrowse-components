---
import { getCollection } from 'astro:content'

import DocsLayout from '../../../layouts/DocsLayout.astro'
import { baseUrl } from '../../../lib/base-url.ts'
import { entrySlug } from '../../../lib/docs-sidebar.ts'

// Section order for the landing page. A tutorial declares its section via the
// `tutorial_category` frontmatter field; anything missing or unlisted falls
// into a trailing "More tutorials" bucket, so a new tutorial always appears
// even before it is categorized.
const CATEGORY_ORDER = [
  'Getting started',
  'Synteny & comparative genomics',
  'Structural variation',
  'Population genomics',
  'Epigenomics & single cell',
  'Transcriptomics & proteins',
]
const FALLBACK = 'More tutorials'

const tutorials = (await getCollection('docs'))
  .filter(entry => entry.id.startsWith('tutorials/'))
  .map(entry => ({
    href: `${baseUrl}/docs/${entrySlug(entry.id)}/`,
    title: entry.data.title,
    description: entry.data.description,
    category: entry.data.tutorial_category ?? FALLBACK,
  }))
  .sort((a, b) => a.title.localeCompare(b.title))

const grouped = [...CATEGORY_ORDER, FALLBACK]
  .map(category => ({
    category,
    items: tutorials.filter(t =>
      CATEGORY_ORDER.includes(t.category)
        ? t.category === category
        : category === FALLBACK,
    ),
  }))
  .filter(group => group.items.length > 0)
---

<DocsLayout
  title="Tutorials"
  currentSlug="tutorials"
  description="Step-by-step, data-driven walkthroughs of common JBrowse workflows."
>
  <p class="lead">
    Hands-on walkthroughs of common JBrowse workflows, each built around a real
    dataset.
  </p>
  {
    grouped.map(group => (
      <section class="tut-section">
        <h2 class="tut-heading">{group.category}</h2>
        <div class="tut-grid">
          {group.items.map(tutorial => (
            <a class="tut-card" href={tutorial.href}>
              <span class="tut-title">{tutorial.title}</span>
              {tutorial.description && (
                <span class="tut-desc">{tutorial.description}</span>
              )}
            </a>
          ))}
        </div>
      </section>
    ))
  }
</DocsLayout>

<style>
  .lead {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }
  .tut-section {
    margin: 0 0 2rem;
  }
  .tut-heading {
    font-size: 1.15rem;
    margin: 0 0 0.85rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border);
  }
  .tut-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .tut-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }
  .tut-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .tut-title {
    font-weight: 600;
    color: var(--color-accent);
  }
  .tut-desc {
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }
</style>
