---
import { getCollection } from 'astro:content'
import DocsLayout from '../../layouts/DocsLayout.astro'
import { renderMarkdown } from '../../lib/markdown.ts'
import { entrySlug } from '../../lib/docs-sidebar.ts'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  return docs.map(entry => {
    const slug = entrySlug(entry.id) || undefined
    return { params: { slug }, props: { entry } }
  })
}

const { entry } = Astro.props
const currentSlug = Astro.params.slug ?? ''
const { html, headings } = await renderMarkdown(entry.body)
---

<DocsLayout title={entry.data.title} currentSlug={currentSlug} headings={headings}>
  <Fragment set:html={html} />
</DocsLayout>
