---
import { baseUrl } from '../lib/base-url'
import BaseLayout from '../layouts/BaseLayout.astro'
import { Icon } from 'astro-icon/components'
import btn from '../styles/button.module.css'
import page from '../styles/page.module.css'
import { currentVersion } from '../config.ts'
const ghRelease = `https://github.com/GMOD/jbrowse-components/releases/tag/${currentVersion}`
const desktopBase = `https://github.com/GMOD/jbrowse-components/releases/download/${currentVersion}`
const webZip = `https://github.com/GMOD/jbrowse-components/releases/download/${currentVersion}/jbrowse-web-${currentVersion}.zip`
const lgvExamples = 'https://jbrowse.org/storybook/lgv/'
const cgvExamples = 'https://jbrowse.org/storybook/cgv/'

const desktopDownloads = [
  { os: 'MacOS', suffix: 'mac.dmg', icon: 'mdi:apple' },
  { os: 'Windows', suffix: 'win.exe', icon: 'mdi:microsoft-windows' },
  { os: 'Linux', suffix: 'linux.AppImage', icon: 'mdi:linux' },
]

const resourceCards = [
  {
    title: 'Static image generator',
    icon: 'mdi:image-multiple',
    description: 'Generate images of JBrowse 2 statically on the command line.',
    links: [
      {
        label: '@jbrowse/img',
        href: 'https://www.npmjs.com/package/@jbrowse/img',
      },
    ],
  },
  {
    title: 'React Linear Genome View',
    icon: 'mdi:react',
    description: 'Linear genome browser React component, available on NPM.',
    links: [
      {
        label: 'NPM',
        href: 'https://www.npmjs.com/package/@jbrowse/react-linear-genome-view',
      },
      { label: 'Live examples', href: lgvExamples },
    ],
  },
  {
    title: 'React Circular Genome View',
    icon: 'mdi:react',
    description: 'Circular genome browser React component, available on NPM.',
    links: [
      {
        label: 'NPM',
        href: 'https://www.npmjs.com/package/@jbrowse/react-circular-genome-view',
      },
      { label: 'Live examples', href: cgvExamples },
    ],
  },
  {
    title: 'Jupyter Notebooks',
    icon: 'mdi:notebook-outline',
    description: 'An extension for using JBrowse inside Jupyter notebooks.',
    links: [
      {
        label: 'Documentation',
        href: 'https://gmod.github.io/jbrowse-jupyter/docs/html/index.html',
      },
      { label: 'Source code', href: 'https://github.com/GMOD/jbrowse-jupyter' },
    ],
  },
  {
    title: 'Dash — Python',
    icon: 'mdi:language-python',
    description: 'Use JBrowse as a Dash component in Python apps.',
    links: [
      {
        label: 'GMOD/dash_jbrowse',
        href: 'https://github.com/GMOD/dash_jbrowse',
      },
    ],
  },
  {
    title: 'R/Shiny widget',
    icon: 'mdi:language-r',
    description: 'JBrowseR, an R package on CRAN.',
    links: [{ label: 'JBrowseR', href: 'https://gmod.github.io/JBrowseR/' }],
  },
]
---

<BaseLayout title="Download JBrowse 2">
  <div class={page.content}>
    <h1>Download JBrowse 2</h1>
    <p>
      JBrowse 2 is a new browser for today's increasingly complex data. We make
      several different products for use in different scenarios, choose the one
      below that best fits your needs.
    </p>

    <h2>JBrowse Desktop</h2>
    <p>
      A standalone app that runs on your own computer that can view data from
      many sources.
    </p>
    <div class="download-cards">
      {
        desktopDownloads.map(({ os, suffix, icon }) => (
          <div class="download-card">
            <div class="card-icon">
              <Icon name={icon} width="40" height="40" />
            </div>
            <h3>{os}</h3>
            <a
              class:list={[btn.btn, btn.btnPrimary, btn.btnSmall]}
              href={`${desktopBase}/jbrowse-desktop-${currentVersion}-${suffix}`}
            >
              Download
            </a>
          </div>
        ))
      }
    </div>
    <p class="caption">
      Check out our <a href={`${baseUrl}/docs/quickstart_desktop/`}
        >quick start guide</a
      >{' '}
      after downloading. Can't find what you're looking for? Check <a
        href={ghRelease}>other platforms</a
      >.
    </p>

    <h2>JBrowse Web</h2>
    <p>
      Run a full-featured genome browser with many types of built-in views on
      your own website.
    </p>
    <div class="web-download">
      <a class:list={[btn.btn, btn.btnPrimary]} href={webZip}
        >Download JBrowse Web</a
      >
    </div>
    <p>
      Consider installing the JBrowse CLI tools (below), which can be used to
      create and manage JBrowse Web instances from the command line.
    </p>

    <h2 id="jbrowse-cli-tools">JBrowse CLI tools</h2>
    <p>
      The JBrowse CLI helps administrators add genome assemblies, tracks, and
      more to their config files.
    </p>
    <pre><code>npm install -g @jbrowse/cli</code></pre>
    <p>
      After installing, check out our{' '}
      <a href={`${baseUrl}/docs/quickstart_web/`}>quick-start guide</a>.
    </p>

    <h2>More ways to use JBrowse</h2>
    <p>
      Embed JBrowse in your own application, script, or notebook with one of
      these integrations.
    </p>
    <div class="resource-cards">
      {
        resourceCards.map(({ title, icon, description, links }) => (
          <div class="resource-card">
            <div class="resource-icon">
              <Icon name={icon} width="28" height="28" />
            </div>
            <h3>{title}</h3>
            <p>{description}</p>
            <div class="resource-links">
              {links.map(({ label, href }) => (
                <a href={href}>{label}</a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
    <p class="caption">
      More info in the <a href={`${baseUrl}/docs/embedded_components/`}
        >embedded docs</a
      >{' '}
      for the React components, including examples with create-react-app, vite, next.js,
      and vanillajs.
    </p>
  </div>
</BaseLayout>

<style>
  .download-cards {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin: 1.5rem 0;
  }
  .download-card {
    background: var(--color-inline-code-bg);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
    min-width: 160px;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .card-icon {
    font-size: 2rem;
  }
  .download-card h3 {
    margin: 0;
  }
  .web-download {
    margin: 1rem 0;
  }
  .caption {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .resource-cards {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 1rem 0 1.5rem;
  }
  .resource-card {
    flex: 1 1 220px;
    min-width: 220px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.15s;
  }
  .resource-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .resource-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-accent) 15%, white);
    color: var(--color-accent-dark);
  }
  .resource-card h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }
  .resource-card p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    flex: 1;
  }
  .resource-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    font-weight: 500;
  }
  pre {
    background: var(--color-surface);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
  }
</style>
