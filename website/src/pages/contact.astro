---
import NewsletterSignup from '../components/NewsletterSignup.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { baseUrl } from '../lib/base-url.ts'
import { followIcons } from '../lib/follow-icons.ts'
import { newsletterApiUrl } from '../lib/newsletter.ts'
import page from '../styles/page.module.css'
---

<BaseLayout
  title="Contact — JBrowse"
  description="Get in touch with the JBrowse team and community — discussion forums, issue tracker, chat, mailing list, newsletter, RSS feed, and social media."
>
  <div class={page.content}>
    <h1>Contact us</h1>

    <h2>Get in touch</h2>
    <ul>
      <li>
        Discussion forum: <a
          href="https://github.com/GMOD/jbrowse-components/discussions"
          >github.com/GMOD/jbrowse-components/discussions</a
        >
      </li>
      <li>
        Issues and feature requests: <a
          href="https://github.com/GMOD/jbrowse-components/issues/new/choose"
          >github.com/GMOD/jbrowse-components/issues</a
        >
      </li>
      <li>
        Chat: <a href="https://app.gitter.im/#/room/#GMOD_jbrowse2:gitter.im"
          >Gitter</a
        >
      </li>
      <li>
        Mailing list: send email to <code>gmod-ajax@lists.sourceforge.net</code>
      </li>
      <li>
        Email: <a href="mailto:jbrowse2@berkeley.edu">jbrowse2@berkeley.edu</a>
      </li>
      <li>
        Feedback: <a href="https://forms.gle/CRf9Ur9iXu2uuz1o9">Google Form</a>
      </li>
    </ul>

    {
      newsletterApiUrl && (
        <>
          <h2 id="newsletter">Newsletter</h2>
          <p>Subscribe to receive JBrowse release announcements by email:</p>
          <NewsletterSignup />
        </>
      )
    }

    <h2>Follow along</h2>
    <ul class="follow">
      <li>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d={followIcons.rss} fill="currentColor"></path>
        </svg>
        Blog RSS feed: <a href={`${baseUrl}/rss.xml`}
          >subscribe in your feed reader</a
        >
      </li>
      <li>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d={followIcons.bluesky} fill="currentColor"></path>
        </svg>
        Bluesky: <a href="https://bsky.app/profile/jbrowse.org"
          >bsky.app/profile/jbrowse.org</a
        >
      </li>
      <li>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d={followIcons.mastodon} fill="currentColor"></path>
        </svg>
        Mastodon: <a href="https://genomic.social/@usejbrowse"
          >genomic.social/@usejbrowse</a
        >
      </li>
      <li>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d={followIcons.youtube} fill="currentColor"></path>
        </svg>
        YouTube: <a href="https://www.youtube.com/@jbrowse6740"
          >youtube.com/@jbrowse6740</a
        >
      </li>
    </ul>
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 400;
    margin: 0 0 1.5rem;
  }
  h2 {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 1.5rem 0 0.5rem;
  }
  /* Icons sit inline with the text, so the list keeps its normal bullets. */
  .follow svg {
    width: 16px;
    height: 16px;
    vertical-align: -3px;
    margin-right: 0.35rem;
    color: var(--color-text-muted);
  }
</style>
