---
import NewsletterSignup from '../components/NewsletterSignup.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { baseUrl } from '../lib/base-url.ts'
import { followIcons } from '../lib/follow-icons.ts'
import { newsletterApiUrl } from '../lib/newsletter.ts'
import page from '../styles/page.module.css'

const follow = [
  {
    icon: 'rss',
    label: 'Blog RSS feed',
    href: `${baseUrl}/rss.xml`,
    text: 'subscribe in your feed reader',
  },
  {
    icon: 'bluesky',
    label: 'Bluesky',
    href: 'https://bsky.app/profile/jbrowse.org',
    text: 'bsky.app/profile/jbrowse.org',
  },
  {
    icon: 'mastodon',
    label: 'Mastodon',
    href: 'https://genomic.social/@usejbrowse',
    text: 'genomic.social/@usejbrowse',
  },
  {
    icon: 'youtube',
    label: 'YouTube',
    href: 'https://www.youtube.com/@jbrowse6740',
    text: 'youtube.com/@jbrowse6740',
  },
] as const
---

<BaseLayout
  title="Contact — JBrowse"
  description="Get in touch with the JBrowse team and community — discussion forums, issue tracker, chat, mailing list, newsletter, RSS feed, and social media."
>
  <div class={page.content}>
    <h1>Contact us</h1>

    <h2>Get in touch</h2>
    <ul>
      <li>
        Discussion forum: <a
          href="https://github.com/GMOD/jbrowse-components/discussions"
          >github.com/GMOD/jbrowse-components/discussions</a
        >
      </li>
      <li>
        Issues and feature requests: <a
          href="https://github.com/GMOD/jbrowse-components/issues/new/choose"
          >github.com/GMOD/jbrowse-components/issues</a
        >
      </li>
      <li>
        Chat: <a href="https://app.gitter.im/#/room/#GMOD_jbrowse2:gitter.im"
          >Gitter</a
        >
      </li>
      <li>
        Mailing list: send email to <code>gmod-ajax@lists.sourceforge.net</code>
      </li>
      <li>
        Email: <a href="mailto:jbrowse2@berkeley.edu">jbrowse2@berkeley.edu</a>
      </li>
      <li>
        Feedback: <a href="https://forms.gle/CRf9Ur9iXu2uuz1o9">Google Form</a>
      </li>
    </ul>

    {
      newsletterApiUrl && (
        <>
          <h2 id="newsletter">Newsletter</h2>
          <p>Subscribe to receive JBrowse release announcements by email:</p>
          <NewsletterSignup />
        </>
      )
    }

    <h2>Follow along</h2>
    <ul class="follow">
      {
        follow.map(({ icon, label, href, text }) => (
          <li>
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d={followIcons[icon]} fill="currentColor" />
            </svg>
            <span>
              {label}: <a href={href}>{text}</a>
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 400;
    margin: 0 0 1.5rem;
  }
  h2 {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 1.5rem 0 0.5rem;
  }
  .follow {
    list-style: none;
    padding: 0;
  }
  .follow li {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0.4rem 0;
  }
  /* Baseline alignment puts the icon a touch high next to the text box. */
  .follow svg {
    flex-shrink: 0;
    transform: translateY(3px);
    color: var(--color-text-muted);
  }
</style>
