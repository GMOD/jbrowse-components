---
import { Buffer } from 'node:buffer'
import { closeSync, openSync, readSync } from 'node:fs'
import { fileURLToPath } from 'node:url'

import DocsSidebarNav from '../components/DocsSidebarNav.astro'
import SidebarLayout from '../layouts/SidebarLayout.astro'
import { baseUrl } from '../lib/base-url.ts'
import {
  gallerySections,
  itemGuideHref,
  itemHref,
  itemImg,
  itemLiveHref,
} from '../lib/gallery.ts'
import page from '../styles/page.module.css'

// Intrinsic dimensions from the PNG IHDR header (width @ byte 16, height @ 20),
// stamped on each <img> so the browser reserves the right box and the page
// doesn't jump as the lazy-loaded screenshots arrive.
function pngSize(file: string) {
  const path = fileURLToPath(new URL(`../../static/img/${file}`, import.meta.url))
  const fd = openSync(path, 'r')
  const buf = Buffer.alloc(24)
  readSync(fd, buf, 0, 24, 0)
  closeSync(fd)
  return { width: buf.readUInt32BE(16), height: buf.readUInt32BE(20) }
}

// Sections shown as screenshot cards vs. compact link lists: an item appears in
// the card grid when it has a figure, otherwise in the "more examples" list.
// `demoOnly` items (entry points / hubs) are shown only on the demos page.
const sections = gallerySections
  .map(s => ({
    ...s,
    cards: s.items.flatMap(i => {
      const file = itemImg(i)
      return file && !i.demoOnly ? [{ item: i, size: pngSize(file) }] : []
    }),
    links: s.items.filter(i => !itemImg(i) && !i.demoOnly),
  }))
  .filter(s => s.cards.length > 0 || s.links.length > 0)
---

<SidebarLayout
  title="JBrowse 2 Visualizations Gallery"
  description="A gallery of genome visualizations built with JBrowse 2, including synteny, structural variants, alignments, methylation, and Hi-C contact matrices."
  toggleLabel="Explore"
  navLabel="Site navigation"
>
  <DocsSidebarNav slot="nav" currentSlug="gallery" />
  <div class="showcase-main">
    <div class={`${page.content} wide`}>
      <h1>JBrowse 2 visualizations gallery</h1>

      {
        sections.map(s => (
          <section>
            <h2 id={s.id}>{s.title}</h2>
            {s.cards.length > 0 && (
              <div class="grid">
                {s.cards.map(({ item, size }) => {
                  const src = `${baseUrl}/img/${itemImg(item)}`
                  const liveHref = itemLiveHref(item)
                  const guideHref = itemGuideHref(item, baseUrl)
                  const guideLabel = item.guide?.startsWith('tutorials/')
                    ? 'Read the tutorial ↗'
                    : 'Read the guide ↗'
                  // Enlarging opens the live view when there is one, else the guide.
                  const primaryHref = liveHref || guideHref
                  const primaryLabel = liveHref ? 'Open in JBrowse ↗' : guideLabel
                  return (
                    <figure class="card">
                      <button
                        type="button"
                        class="card-img-btn"
                        data-full={src}
                        data-label={item.label}
                        data-href={primaryHref}
                        data-open-label={primaryLabel}
                        aria-label={`Enlarge: ${item.label}`}
                      >
                        <img
                          src={src}
                          alt={item.label}
                          loading="lazy"
                          width={size.width}
                          height={size.height}
                        />
                      </button>
                      <figcaption>
                        <h3 class="card-title">{item.label}</h3>
                        {item.description && <p>{item.description}</p>}
                        <p class="card-links">
                          {liveHref && (
                            <a href={liveHref} class="card-open">
                              Open in JBrowse ↗
                            </a>
                          )}
                          {guideHref && (
                            <a href={guideHref} class="card-open">
                              {guideLabel}
                            </a>
                          )}
                        </p>
                      </figcaption>
                    </figure>
                  )
                })}
              </div>
            )}
            {s.links.length > 0 && (
              <>
                {s.cards.length > 0 && <p class="more">More examples</p>}
                <ul class="links">
                  {s.links.map(item => (
                    <li>
                      <a href={itemHref(item, baseUrl)}>{item.label}</a>
                      {item.description && <span> — {item.description}</span>}
                    </li>
                  ))}
                </ul>
              </>
            )}
          </section>
        ))
      }
    </div>
  </div>

  <div id="lightbox" class="lightbox" hidden>
    <button type="button" class="lightbox-close" aria-label="Close">×</button>
    <figure class="lightbox-fig">
      <img id="lightbox-img" src="" alt="" />
      <figcaption>
        <span id="lightbox-caption"></span>
        <a id="lightbox-link" class="lightbox-open" href=""></a>
      </figcaption>
    </figure>
  </div>
</SidebarLayout>

<script>
  const lb = document.getElementById('lightbox')!
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement
  const lbCaption = document.getElementById('lightbox-caption')!
  const lbLink = document.getElementById('lightbox-link') as HTMLAnchorElement

  function openLightbox(btn: HTMLElement) {
    lbImg.src = btn.dataset.full ?? ''
    lbImg.alt = btn.dataset.label ?? ''
    lbCaption.textContent = btn.dataset.label ?? ''
    lbLink.href = btn.dataset.href ?? ''
    lbLink.textContent = btn.dataset.openLabel ?? ''
    lb.hidden = false
    document.body.style.overflow = 'hidden'
  }

  function closeLightbox() {
    lb.hidden = true
    lbImg.src = ''
    document.body.style.overflow = ''
  }

  for (const btn of document.querySelectorAll<HTMLElement>('.card-img-btn')) {
    btn.addEventListener('click', () => {
      openLightbox(btn)
    })
  }

  // Backdrop, image, or close-button click closes; only the "open" link passes
  // through (it navigates).
  lb.addEventListener('click', e => {
    const target = e.target as HTMLElement
    if (target !== lbLink) {
      closeLightbox()
    }
  })

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !lb.hidden) {
      closeLightbox()
    }
  })
</script>

<style>
  .showcase-main {
    flex: 1;
    min-width: 0;
  }
  .wide {
    max-width: 1100px;
  }

  h1 {
    margin: 0 0 1rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
  }
  h2 {
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: 5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .card {
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .card + .card {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }
  .card-img-btn {
    display: block;
    width: 100%;
    padding: 0;
    margin: 0;
    border: 1px solid var(--color-border);
    background: none;
    cursor: pointer;
  }
  .card img {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.15s;
  }
  .card-img-btn:hover img {
    filter: brightness(0.92);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.85);
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 96vw;
    max-height: 92vh;
  }
  .lightbox-fig img {
    max-width: 96vw;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    cursor: zoom-out;
  }
  .lightbox-fig figcaption {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    align-items: center;
    justify-content: center;
    margin-top: 0.85rem;
    color: #fff;
    font-size: 0.95rem;
    text-align: center;
  }
  .lightbox-open {
    color: #6ab0ff;
    font-weight: 600;
    white-space: nowrap;
  }
  .lightbox-close {
    position: absolute;
    top: 0.75rem;
    right: 1.25rem;
    padding: 0;
    border: none;
    background: none;
    color: #fff;
    font-size: 2.25rem;
    line-height: 1;
    cursor: pointer;
  }
  figcaption {
    padding: 0.5rem 0 0;
  }
  .card-title {
    margin: 0 0 0.25rem;
  }
  figcaption p {
    margin: 0.25rem 0;
  }
  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    margin: 0.4rem 0 0;
  }
  .card-open {
    display: inline-block;
  }

  .more {
    margin: 1.25rem 0 0.25rem;
  }
  .links {
    margin: 0.25rem 0;
    padding-left: 1.25rem;
    line-height: 1.7;
  }
</style>
