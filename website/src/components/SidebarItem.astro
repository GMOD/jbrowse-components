---
import SidebarItem from './SidebarItem.astro'
import { containsSlug } from '../lib/docs-sidebar.ts'

import type { SidebarEntry } from '../lib/docs-sidebar.ts'

interface Props {
  item: SidebarEntry
  currentSlug: string
}
const { item, currentSlug } = Astro.props
---

{
  item.type === 'link' ? (
    <li>
      <a
        href={item.href}
        class:list={[{ active: item.slug === currentSlug }]}
        aria-current={item.slug === currentSlug ? 'page' : undefined}
      >
        {item.label}
      </a>
    </li>
  ) : (
    <li>
      <details open={containsSlug(item, currentSlug)}>
        <summary>{item.label}</summary>
        <ul>
          {item.items.map(child => (
            <SidebarItem item={child} currentSlug={currentSlug} />
          ))}
        </ul>
      </details>
    </li>
  )
}
