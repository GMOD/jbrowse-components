---
import { Icon } from 'astro-icon/components'

import NewsletterSignup from './NewsletterSignup.astro'
import { baseUrl } from '../lib/base-url.ts'
import { newsletterApiUrl } from '../lib/newsletter.ts'
import btn from '../styles/button.module.css'

// Teaser cards for the gallery preview grid. `img` names a thumbnail in
// static/img/home-gallery/; the destination is a /gallery/#<anchor> section, or
// a /docs/<guide>/ page for capabilities the gallery has no section for.
interface GalleryCard {
  img: string
  label: string
  anchor?: string
  guide?: string
}
const galleryPreview: GalleryCard[] = [
  {
    img: 'synteny',
    label: 'Synteny & whole-genome comparison',
    anchor: 'synteny',
  },
  { img: 'sv', label: 'Structural variants', anchor: 'sv' },
  {
    img: 'alignments',
    label: 'Long reads & base modifications',
    anchor: 'alignments',
  },
  { img: 'variants', label: 'GWAS & population variants', anchor: 'variants' },
  { img: 'hic', label: 'Hi-C contact maps', anchor: 'hic' },
  { img: 'copynumber', label: 'Copy number & coverage', anchor: 'copynumber' },
  {
    img: 'genes',
    label: 'Collapsed introns & gene browsing',
    anchor: 'genes',
  },
  {
    img: 'protein',
    label: '3D protein structures',
    guide: 'tutorials/protein_structure',
  },
]
---

<div class="outer-box">
  <!-- Hero row -->
  <div class="hero-row">
    <div class="hero-text">
      <h1 class="hero-title">JBrowse</h1>
      <p class="hero-subtitle">The next-generation genome browser</p>
      <p class="body-text">
        Open source, and runs on the web, on your desktop, or embedded in your
        app.
      </p>
      <div class="btn-row">
        <a class:list={[btn.btn, btn.btnPrimary]} href={`${baseUrl}/download/`}>
          <Icon name="mdi:tray-arrow-down" width="20" height="20" />
          Download
        </a>
        <a class:list={[btn.btn, btn.btnAccent]} href={`${baseUrl}/demos/`}>
          <Icon name="mdi:play-circle-outline" width="20" height="20" />
          Live demos
        </a>
      </div>
      {
        newsletterApiUrl && (
          <div class="newsletter-hero">
            <p class="newsletter-label">
              Get notified about new releases (
              <a href={`${baseUrl}/blog/`}>latest release notes</a>)
            </p>
            <NewsletterSignup />
          </div>
        )
      }
    </div>
    <div class="hero-image">
      <img
        src={`${baseUrl}/img/screenshot.webp`}
        width="1400"
        height="747"
        fetchpriority="high"
        alt="JBrowse linear genome view of human chr10 at CUZD1: NCBI RefSeq genes, a somatic structural-variant VCF calling a 1.8kb deletion over two exons, and a PacBio HiFi pileup with coverage where the reads carrying that deletion sort to the top as a dark block"
      />
    </div>
  </div>
</div>

<div class="outer-box">
  <!-- Gallery preview -->
  <div class="section-box">
    <h2 class="section-title">Explore the gallery</h2>
    <p class="body-text">
      Worked examples that open live in the browser, most with a tutorial.
    </p>
    <div class="gallery-grid">
      {
        galleryPreview.map(g => (
          <a
            class="gallery-card"
            href={
              g.guide
                ? `${baseUrl}/docs/${g.guide}/`
                : `${baseUrl}/gallery/#${g.anchor}`
            }
          >
            <img
              class="gallery-thumb"
              src={`${baseUrl}/img/home-gallery/${g.img}.webp`}
              loading="lazy"
              decoding="async"
              alt=""
            />
            <span class="gallery-card-label">{g.label}</span>
          </a>
        ))
      }
    </div>
    <div class="btn-row">
      <a class:list={[btn.btn, btn.btnPrimary]} href={`${baseUrl}/gallery/`}>
        Browse the full gallery
      </a>
      <a
        class:list={[btn.btn, btn.btnAccent]}
        href={`${baseUrl}/docs/tutorials/`}
      >
        Follow a tutorial
      </a>
    </div>
  </div>

  <!-- Genome Hubs -->
  <div class="section-box">
    <h2 class="section-title">Ready-made genome browsers</h2>
    <div class="hubs-row">
      <div class="hubs-text">
        <p class="body-text">
          Browsers for thousands of species, also built into the <a
            href={`${baseUrl}/download/`}>JBrowse Desktop</a
          > genome picker.
        </p>
        <ul class="hubs-list">
          <li>
            hg38, hg19 and more, preloaded with UCSC Genome Browser tracks
          </li>
          <li>
            Thousands of plant, animal and microbial assemblies from UCSC
            GenArk/NCBI Genomes
          </li>
          <li>Ortholog browsing across species</li>
        </ul>
        <p class="body-text">
          <a
            href="https://genomes.jbrowse.org"
            target="_blank"
            rel="noopener noreferrer">genomes.jbrowse.org ↗</a
          >
        </p>
      </div>
      <div class="hubs-image">
        <img
          src={`${baseUrl}/img/desktop-available-genomes.webp`}
          width="1400"
          height="764"
          loading="lazy"
          decoding="async"
          alt="JBrowse Desktop 'Available genomes' picker, a searchable list of human, mouse, and other assemblies each with a one-click launch link"
        />
      </div>
    </div>
  </div>

  <!-- Resources -->
  <div class="section-box">
    <h2 class="section-title">Get started</h2>
    <div class="cards">
      <div class="card">
        <Icon
          class="card-icon"
          name="mdi:rocket-launch-outline"
          width="28"
          height="28"
        />
        <h3 class="card-title">Install &amp; run</h3>
        <p class="card-desc">Open your first genome.</p>
        <ul class="card-links">
          <li>
            <a href={`${baseUrl}/docs/quickstart_desktop/`}
              >Desktop quick start</a
            >
          </li>
          <li>
            <a href={`${baseUrl}/docs/quickstart_web/`}>Web quick start</a>
          </li>
        </ul>
      </div>
      <div class="card">
        <Icon
          class="card-icon"
          name="mdi:book-open-page-variant-outline"
          width="28"
          height="28"
        />
        <h3 class="card-title">Learn</h3>
        <p class="card-desc">Using, configuring and extending JBrowse.</p>
        <ul class="card-links">
          <li><a href={`${baseUrl}/docs/user_guide/`}>User guide</a></li>
          <li><a href={`${baseUrl}/docs/config_guide/`}>Config guide</a></li>
          <li>
            <a href={`${baseUrl}/docs/developer_guide/`}>Developer guide</a>
          </li>
          <li><a href={`${baseUrl}/docs/tutorials/`}>Tutorials</a></li>
          <li><a href={`${baseUrl}/features/`}>Full feature list</a></li>
        </ul>
      </div>
      <div class="card">
        <Icon class="card-icon" name="mdi:code-tags" width="28" height="28" />
        <h3 class="card-title">Build with it</h3>
        <p class="card-desc">Embed JBrowse and extend it with plugins.</p>
        <ul class="card-links">
          <li>
            <a href={`${baseUrl}/docs/tutorials/embed_linear_genome_view/`}
              >Embed a genome view</a
            >
          </li>
          <li>
            <a href={`${baseUrl}/docs/embedded_components/`}
              >Embedded components reference</a
            >
          </li>
          <li>
            <a href={`${baseUrl}/docs/developer_guides/simple_plugin/`}
              >Write a plugin</a
            >
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Citation -->
  <div class="section-box">
    <h2 class="section-title">Citation</h2>
    <p class="body-text">
      Citations are how the consortium demonstrates JBrowse's value when
      applying for funding. If you publish research using JBrowse, please cite:
    </p>
    <cite>
      Diesh <em>et al</em>, 2023. JBrowse 2: a modular genome browser with views
      of synteny and structural variation. Genome Biology 24:74.
      <a href="https://doi.org/10.1186/s13059-023-02914-z">
        https://doi.org/10.1186/s13059-023-02914-z
      </a>
    </cite>
  </div>

  <!-- Funding -->
  <div class="section-box">
    <h2 class="section-title">Funding and collaboration</h2>
    <p class="body-text">
      Supported by the US National Institutes of Health (U41 HG003751), the Chan
      Zuckerberg Initiative, the Ontario Institute for Cancer Research (OICR),
      and the University of California, Berkeley. Released under the <a
        href="https://www.apache.org/licenses/LICENSE-2.0"
        >Apache License, Version 2.0</a
      >.
    </p>
  </div>
</div>

<style>
  .hero-title {
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.167;
    margin: 0 0 0.35em;
  }
  .hero-subtitle {
    font-size: clamp(1.4rem, 3.5vw, 2.125rem);
    font-weight: 400;
    line-height: 1.235;
    margin: 0 0 0.35em;
  }
  .section-title {
    font-size: clamp(1.4rem, 3.5vw, 2.125rem);
    font-weight: 400;
    line-height: 1.235;
    margin: 0;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .body-text {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }

  .outer-box {
    max-width: 1600px;
    margin: clamp(0.75rem, 4vw, 3rem) auto;
    padding-left: clamp(1rem, 4vw, 3rem);
    padding-right: clamp(1rem, 4vw, 3rem);
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .newsletter-hero {
    text-align: center;
    padding: 20px 24px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-primary) 5%, white);
    margin-top: 8px;
  }
  .newsletter-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 8px;
  }
  .hubs-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .hubs-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .hubs-list {
    margin: 0;
    padding-left: 1.2rem;
    line-height: 1.6;
  }
  /* A desktop-app screenshot scaled to a phone width is unreadable, and it's
     only reinforcing the text beside it. */
  .hubs-image {
    display: none;
  }
  .hubs-image img {
    border-radius: 8px;
    border: 1px solid var(--color-border);
    height: auto;
    width: 100%;
    display: block;
  }

  /* 8 cards, so cap at 4 columns — auto-fit picks 5 on a wide screen and
     leaves a two-cell hole in the second row. */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .gallery-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }
  .gallery-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .gallery-thumb {
    width: 100%;
    height: 110px;
    object-fit: cover;
    object-position: center top;
    display: block;
    border-bottom: 1px solid var(--color-border);
  }
  .gallery-card-label {
    padding: 0.45rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }
  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .card-icon {
    color: var(--color-primary);
  }
  .card-title {
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0.1rem 0 0;
  }
  .card-desc {
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--color-text-muted);
    margin: 0 0 0.35rem;
  }
  .card-links {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .card-links li {
    margin: 0.3rem 0;
  }
  .hero-image img {
    border-radius: 8px;
    border: 1px solid var(--color-border);
    height: auto;
    width: 100%;
    display: block;
  }

  /* Buttons stretch to share the row on phones, then size to content. */
  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .btn-row > * {
    flex: 1 1 auto;
    justify-content: center;
  }

  .section-box {
    margin-bottom: clamp(2rem, 5vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-card,
    .card {
      transition: none;
    }
    .gallery-card:hover,
    .card:hover {
      transform: none;
    }
  }

  @media (min-width: 640px) {
    .btn-row > * {
      flex: 0 0 auto;
    }
    /* Hero pair only — the gallery's row stays left-aligned under its copy. */
    .hero-text .btn-row {
      justify-content: center;
    }
  }

  @media (min-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .gallery-thumb {
      height: 150px;
    }
    .gallery-card-label {
      padding: 0.55rem 0.75rem;
      font-size: 0.9rem;
    }
    .hero-row {
      flex-direction: row;
      align-items: center;
    }
    .hero-text {
      flex: 50%;
    }
    .hero-image {
      flex: 50%;
    }
    .btn-row {
      margin: 16px 0;
    }
    .hubs-row {
      flex-direction: row;
      align-items: center;
    }
    .hubs-text {
      flex: 50%;
    }
    .hubs-image {
      display: block;
      flex: 50%;
    }
  }
</style>
