---
import { Icon } from 'astro-icon/components'

import NewsletterSignup from './NewsletterSignup.tsx'
import { baseUrl } from '../lib/base-url.ts'
import btn from '../styles/button.module.css'

// Teaser cards for the gallery preview grid. `img` names a thumbnail in
// static/img/home-gallery/; the destination is a /gallery/#<anchor> section, or
// a /docs/<guide>/ page for capabilities the gallery has no section for.
interface GalleryCard {
  img: string
  label: string
  anchor?: string
  guide?: string
}
const galleryPreview: GalleryCard[] = [
  {
    img: 'synteny',
    label: 'Synteny & whole-genome comparison',
    anchor: 'synteny',
  },
  { img: 'sv', label: 'Structural variants', anchor: 'sv' },
  {
    img: 'alignments',
    label: 'Long reads & base modifications',
    anchor: 'alignments',
  },
  { img: 'variants', label: 'Variants & populations', anchor: 'variants' },
  { img: 'hic', label: 'Hi-C contact maps', anchor: 'hic' },
  { img: 'copynumber', label: 'Copy number & coverage', anchor: 'copynumber' },
  { img: 'genes', label: 'Genes & compact genomes', anchor: 'genes' },
  {
    img: 'protein',
    label: '3D protein structures',
    guide: 'tutorials/protein_structure',
  },
]
---

<div class="outer-box">
  <!-- Hero row -->
  <div class="hero-row">
    <div class="hero-text">
      <h1 class="hero-title">JBrowse</h1>
      <p class="hero-subtitle">The next-generation genome browser</p>
      <p class="body-text">
        JBrowse is a genome browser that runs on the web, on your desktop, or
        embedded in your app.
      </p>
      <div class="btn-row">
        <a class:list={[btn.btn, btn.btnPrimary]} href={`${baseUrl}/download/`}>
          <Icon name="mdi:tray-arrow-down" width="20" height="20" />
          Download
        </a>
        <a class:list={[btn.btn, btn.btnAccent]} href={`${baseUrl}/demos/`}>
          <Icon name="mdi:play-circle-outline" width="20" height="20" />
          Live demos
        </a>
      </div>
      <div class="newsletter-hero">
        <p class="newsletter-label">
          Get notified about new releases &mdash; <a href={`${baseUrl}/blog/`}
            >see latest release notes</a
          >
        </p>
        <NewsletterSignup client:load />
      </div>
    </div>
    <div class="hero-image">
      <img
        src={`${baseUrl}/img/screenshot.webp`}
        width="1362"
        height="731"
        alt="JBrowse linear genome view showing read alignments, coverage, and gene annotations"
      />
    </div>
  </div>
</div>

<!-- Genome Hubs -->
<div class="outer-box">
  <div class="hubs-band">
    <div class="hubs-text">
      <h2 class="section-title hubs-title">
        Thousands of preconfigured genomes
      </h2>
      <p class="body-text">
        JBrowse Genome Hubs hosts genome browsers for thousands of species on
        the web. The same assemblies are built into JBrowse Desktop's genome
        picker, so you can open one without configuring any data.
      </p>
      <ul class="hubs-list">
        <li>Human and mouse assemblies (hg19, hg38, T2T hs1, mm10, mm39)</li>
        <li>
          The UCSC GenArk collection of plant, animal, and microbial genomes
        </li>
        <li>The Human Pangenome (HPRC) set of 232 diploid assemblies</li>
        <li>VGP, CCGP, and BRC collections</li>
      </ul>
      <div class="btn-row hubs-btn-row">
        <a
          class:list={[btn.btn, btn.btnAccent]}
          href="https://genomes.jbrowse.org"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open Genome Hubs
          <Icon name="mdi:open-in-new" width="18" height="18" />
        </a>
        <a class:list={[btn.btn, btn.btnPrimary]} href={`${baseUrl}/download/`}>
          <Icon name="mdi:tray-arrow-down" width="18" height="18" />
          Get JBrowse Desktop
        </a>
      </div>
    </div>
    <div class="hubs-image">
      <img
        src={`${baseUrl}/img/desktop-available-genomes.webp`}
        width="1400"
        height="764"
        loading="lazy"
        decoding="async"
        alt="JBrowse Desktop 'Available genomes' picker, a searchable list of human, mouse, and other assemblies each with a one-click launch link"
      />
    </div>
  </div>
</div>

<div class="outer-box">
  <!-- Gallery preview -->
  <div class="section-box">
    <h2 class="section-title">Explore the gallery</h2>
    <p class="body-text">
      Worked examples across the data types and views JBrowse supports. Most
      open live in the browser, and many have a step-by-step tutorial.
    </p>
    <div class="gallery-grid">
      {
        galleryPreview.map(g => (
          <a
            class="gallery-card"
            href={
              g.guide
                ? `${baseUrl}/docs/${g.guide}/`
                : `${baseUrl}/gallery/#${g.anchor}`
            }
          >
            <img
              class="gallery-thumb"
              src={`${baseUrl}/img/home-gallery/${g.img}.webp`}
              loading="lazy"
              decoding="async"
              alt={g.label}
            />
            <span class="gallery-card-label">{g.label}</span>
          </a>
        ))
      }
    </div>
    <div class="btn-row gallery-btn-row">
      <a class:list={[btn.btn, btn.btnPrimary]} href={`${baseUrl}/gallery/`}>
        Browse the full gallery
      </a>
      <a
        class:list={[btn.btn, btn.btnAccent]}
        href={`${baseUrl}/docs/tutorials/`}
      >
        Follow a tutorial
      </a>
    </div>
  </div>

  <!-- Resources -->
  <div class="section-box">
    <h2 class="section-title">Get started</h2>
    <div class="cards">
      <div class="card">
        <Icon
          class="card-icon"
          name="mdi:rocket-launch-outline"
          width="28"
          height="28"
        />
        <h3 class="card-title">Install &amp; run</h3>
        <p class="card-desc">
          Open your first genome in the desktop app or straight from the
          browser.
        </p>
        <ul class="card-links">
          <li>
            <a href={`${baseUrl}/docs/quickstart_desktop/`}
              >Desktop quick start</a
            >
          </li>
          <li>
            <a href={`${baseUrl}/docs/quickstart_web/`}>Web quick start</a>
          </li>
        </ul>
      </div>
      <div class="card">
        <Icon
          class="card-icon"
          name="mdi:book-open-page-variant-outline"
          width="28"
          height="28"
        />
        <h3 class="card-title">Learn</h3>
        <p class="card-desc">
          Guides for using, configuring, and extending JBrowse.
        </p>
        <ul class="card-links">
          <li><a href={`${baseUrl}/docs/user_guide/`}>User guide</a></li>
          <li><a href={`${baseUrl}/docs/config_guide/`}>Config guide</a></li>
          <li>
            <a href={`${baseUrl}/docs/developer_guide/`}>Developer guide</a>
          </li>
          <li><a href={`${baseUrl}/docs/tutorials/`}>Tutorials</a></li>
          <li><a href={`${baseUrl}/features/`}>Full feature list</a></li>
        </ul>
      </div>
      <div class="card">
        <Icon class="card-icon" name="mdi:code-tags" width="28" height="28" />
        <h3 class="card-title">Build with it</h3>
        <p class="card-desc">
          Embed JBrowse in your app and extend it with plugins.
        </p>
        <ul class="card-links">
          <li>
            <a href={`${baseUrl}/docs/tutorials/embed_linear_genome_view/`}
              >Embed a genome view</a
            >
          </li>
          <li>
            <a href={`${baseUrl}/docs/embedded_components/`}
              >Embedded components reference</a
            >
          </li>
          <li>
            <a href={`${baseUrl}/docs/developer_guides/simple_plugin/`}
              >Write a plugin</a
            >
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Citation -->
  <div class="section-box">
    <h2 class="section-title">Citation</h2>
    <p class="body-text">
      We at the JBrowse Consortium are working to make JBrowse a pluggable,
      open-source computational platform for integrating many kinds of
      biological data from many different places.
    </p>
    <p class="body-text">
      Research citations are one of the main metrics the consortium uses to
      demonstrate our relevance and utility when applying for funding to
      continue our work. If you use JBrowse in research that you publish, please
      cite the most recent JBrowse paper:
    </p>
    <cite>
      Diesh <em>et al</em>, 2023. JBrowse 2: a modular genome browser with views
      of synteny and structural variation. Genome Biology 24:74.
      <a href="https://doi.org/10.1186/s13059-023-02914-z">
        https://doi.org/10.1186/s13059-023-02914-z
      </a>
    </cite>
  </div>

  <!-- Funding -->
  <div class="section-box">
    <h2 class="section-title">Funding and collaboration</h2>
    <p class="body-text">
      JBrowse development has received support from the US National Institutes
      of Health (U41 HG003751), The Chan Zuckerberg Initiative, The Ontario
      Institute for Cancer Research (OICR), and the University of California,
      Berkeley. JBrowse is released under the{' '}
      <a href="https://www.apache.org/licenses/LICENSE-2.0"
        >Apache License, Version 2.0</a
      >.
    </p>
  </div>
</div>

<style>
  .hero-title {
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.167;
    margin: 0 0 0.35em;
  }
  .hero-subtitle {
    font-size: clamp(1.4rem, 3.5vw, 2.125rem);
    font-weight: 400;
    line-height: 1.235;
    margin: 0 0 0.35em;
  }
  .section-title {
    font-size: clamp(1.4rem, 3.5vw, 2.125rem);
    font-weight: 400;
    line-height: 1.235;
    margin: 0;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .body-text {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }

  .outer-box {
    margin: clamp(0.75rem, 4vw, 3rem);
    max-width: 1600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-row {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .newsletter-hero {
    text-align: center;
    padding: 20px 24px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-primary) 5%, white);
    margin-top: 8px;
  }
  .newsletter-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 8px;
  }
  .hubs-band {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    background: color-mix(in srgb, var(--color-accent) 7%, white);
  }
  .hubs-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .hubs-title {
    border-bottom: none;
    padding-bottom: 0;
    color: var(--color-accent-dark);
  }
  .hubs-list {
    margin: 0;
    padding-left: 1.2rem;
    line-height: 1.6;
  }
  .btn-row.hubs-btn-row {
    justify-content: flex-start;
  }
  .hubs-image img {
    border-radius: 8px;
    border: 1px solid var(--color-border);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    height: auto;
    width: 100%;
    display: block;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .gallery-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }
  .gallery-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .gallery-thumb {
    width: 100%;
    height: 150px;
    object-fit: cover;
    object-position: center top;
    display: block;
    border-bottom: 1px solid var(--color-border);
  }
  .gallery-card-label {
    padding: 0.55rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .btn-row.gallery-btn-row {
    justify-content: flex-start;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }
  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .card-icon {
    color: var(--color-primary);
  }
  .card-title {
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0.1rem 0 0;
  }
  .card-desc {
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--color-text-muted);
    margin: 0 0 0.35rem;
  }
  .card-links {
    margin: auto 0 0;
    padding: 0;
    list-style: none;
  }
  .card-links li {
    margin: 0.3rem 0;
  }
  .hero-image img {
    border-radius: 8px;
    border: 4px solid var(--color-border);
    height: auto;
    width: 100%;
    display: block;
  }

  .btn-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-evenly;
    gap: 8px;
  }

  .section-box {
    margin-bottom: clamp(2rem, 5vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (min-width: 900px) {
    .hero-row {
      flex-direction: row;
      align-items: center;
    }
    .hero-text {
      flex: 50%;
    }
    .hero-image {
      flex: 50%;
    }
    .btn-row {
      margin: 16px;
    }
    .hubs-band {
      flex-direction: row;
      align-items: center;
    }
    .hubs-text {
      flex: 45%;
    }
    .hubs-image {
      flex: 55%;
    }
  }
</style>
