---
import { getCollection } from 'astro:content'
import { baseUrl } from '../lib/base-url'
import { blogPath } from '../lib/blog-path'
import SidebarLayout from './SidebarLayout.astro'

interface Props {
  title: string
  currentSlug?: string
}

const { title, currentSlug = '' } = Astro.props

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)

const byYear = new Map<
  string,
  { slug: string; title: string; href: string }[]
>()
for (const post of posts) {
  const slug = blogPath(post)
  const year = slug.split('/')[0]!
  if (!byYear.has(year)) {
    byYear.set(year, [])
  }
  byYear
    .get(year)!
    .push({ slug, title: post.data.title, href: `${baseUrl}/blog/${slug}/` })
}

const years = [...byYear.keys()].sort((a, b) => Number(b) - Number(a))
const currentYear = currentSlug ? currentSlug.split('/')[0]! : ''
---

<SidebarLayout title={title} toggleLabel="Posts" navLabel="Blog navigation">
  <ul slot="nav" class="blog-nav">
    <li>
      <a
        href={`${baseUrl}/blog/`}
        class:list={[{ active: !currentSlug }]}
        aria-current={!currentSlug ? 'page' : undefined}
      >
        All posts
      </a>
    </li>
    {
      years.map(year => (
        <li>
          <details
            open={year === currentYear || (!currentSlug && year === years[0])}
          >
            <summary>{year}</summary>
            <ul>
              {byYear.get(year)!.map(post => (
                <li>
                  <a
                    href={post.href}
                    class:list={[{ active: post.slug === currentSlug }]}
                    aria-current={
                      post.slug === currentSlug ? 'page' : undefined
                    }
                  >
                    {post.title}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        </li>
      ))
    }
  </ul>
  <div class="blog-content">
    <slot />
  </div>
</SidebarLayout>

<style>
  /* long post titles must not wrap the fixed-width sidebar */
  .blog-nav a {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-content {
    flex: 1;
    min-width: 0;
    max-width: min(860px, 100%);
    overflow-wrap: break-word;
  }
</style>
