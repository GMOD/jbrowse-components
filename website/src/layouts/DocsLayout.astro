---
import { getCollection } from 'astro:content'

import SidebarLayout from './SidebarLayout.astro'
import CopyMarkdown from '../components/CopyMarkdown.astro'
import DocsSidebarNav from '../components/DocsSidebarNav.astro'
import TableOfContents from '../components/TableOfContents.astro'
import { baseUrl } from '../lib/base-url.ts'
import { entrySlug } from '../lib/docs-sidebar.ts'

import type { TocItem } from '../lib/rehype-collect-toc.ts'

interface Props {
  title: string
  currentSlug: string
  description?: string
  toc?: TocItem[]
  rawMarkdown?: string
}

const {
  title,
  currentSlug,
  description,
  toc = [],
  rawMarkdown = '',
} = Astro.props

const allDocs = await getCollection('docs')
// Raw-Markdown alternate emitted by emit-raw-markdown.ts (introduction, whose
// slug is "", lives at index.md). Only real doc-collection pages get one — a
// landing page reusing this layout (e.g. /docs/tutorials/) has no emitted .md.
const isRealDoc = allDocs.some(doc => entrySlug(doc.id) === currentSlug)
const mdHref = isRealDoc
  ? `${baseUrl}/docs/${currentSlug || 'index'}.md`
  : undefined
---

<SidebarLayout
  title={`${title} | JBrowse Docs`}
  description={description}
  toggleLabel="Contents"
  navLabel="Documentation navigation"
  mdHref={mdHref}
>
  <DocsSidebarNav slot="nav" currentSlug={currentSlug} />
  <article class="docs-content" data-pagefind-body>
    <h1>{title}</h1>
    <slot />
  </article>
  <CopyMarkdown markdown={rawMarkdown} title={title} />
  {toc.length > 0 && <TableOfContents toc={toc} />}
</SidebarLayout>

{
  /* Figure recipe dialogs are emitted into the markdown HTML by remark-figure,
    so they are wired here rather than mounted as an island. */
}
<script>
  function outsideBox(dialog: HTMLDialogElement, x: number, y: number) {
    const box = dialog.getBoundingClientRect()
    return x < box.left || x > box.right || y < box.top || y > box.bottom
  }

  // open the recipe dialog for a clicked "?" trigger
  document.addEventListener('click', event => {
    const target = event.target
    if (target instanceof HTMLElement) {
      const button = target.closest('[data-spec-dialog]')
      if (button instanceof HTMLElement) {
        const id = button.dataset.specDialog
        const dialog = id ? document.getElementById(id) : null
        if (dialog instanceof HTMLDialogElement && !dialog.open) {
          dialog.showModal()
        }
      }
    }
  })

  // Light-dismiss: close when a click both starts and ends on the backdrop
  // (outside the dialog's own box); the ::backdrop reports the dialog element
  // itself as the target. Requiring the press to *start* on the backdrop stops
  // a text selection dragged out of the dialog from closing it.
  let pressStartedOnBackdrop = false

  document.addEventListener('pointerdown', event => {
    const target = event.target
    pressStartedOnBackdrop =
      target instanceof HTMLDialogElement &&
      target.open &&
      outsideBox(target, event.clientX, event.clientY)
  })

  document.addEventListener('click', event => {
    const target = event.target
    if (
      pressStartedOnBackdrop &&
      target instanceof HTMLDialogElement &&
      target.open &&
      outsideBox(target, event.clientX, event.clientY)
    ) {
      target.close()
    }
  })
</script>

<style>
  .docs-content {
    flex: 1;
    max-width: min(1060px, 100%);
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    min-width: 0;
    line-height: 1.7;
    overflow-wrap: break-word;
  }

  .docs-content h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .docs-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .docs-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    color: var(--color-text);
  }
  .docs-content :global(h4) {
    font-size: 1.05rem;
    font-weight: 700;
    margin-top: 1.5rem;
    color: var(--color-text);
  }

  .docs-content :global(h2),
  .docs-content :global(h3),
  .docs-content :global(h4) {
    position: relative;
  }

  /* Autogenerated config/model docs wrap each section in a <details> whose
     <summary> stands in for an h3 heading — style it to match (see the
     `collapsible` helper in docs/util.ts). */
  .docs-content :global(details) {
    margin-top: 2rem;
  }
  .docs-content :global(details > summary) {
    cursor: pointer;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .docs-content :global(.heading-anchor) {
    opacity: 0;
    margin-left: 0.4rem;
    font-size: 0.8em;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none !important;
    transition: opacity 0.15s;
  }
  .docs-content :global(h2:hover .heading-anchor),
  .docs-content :global(h3:hover .heading-anchor),
  .docs-content :global(h4:hover .heading-anchor) {
    opacity: 1;
  }

  .docs-content :global(pre),
  .docs-content :global(code) {
    font-family: var(--font-mono);
  }
  .docs-content :global(pre) {
    background: var(--color-code-bg);
    color: var(--color-code-text);
    padding: 1rem 1.25rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 1rem 0;
  }
  .docs-content :global(code:not(pre code)) {
    background: var(--color-inline-code-bg);
    border: 1px solid var(--color-inline-code-border);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--color-inline-code-text);
  }
  .docs-content :global(a code) {
    color: inherit;
  }
  .docs-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1rem auto;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }
  .docs-content :global(figure) {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem;
    margin: 1.5rem 0;
    background: var(--color-surface);
  }
  .docs-content :global(figcaption) {
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }
  .docs-content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
    overflow-x: auto;
    display: block;
  }
  .docs-content :global(th),
  .docs-content :global(td) {
    border-bottom: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .docs-content :global(th) {
    border-bottom: 2px solid var(--color-border);
    font-weight: 600;
  }
  .docs-content :global(tr:nth-child(even)) {
    background: var(--color-table-stripe);
  }
  .docs-content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    margin: 1.5rem 0;
    padding: 0.5rem 1.25rem;
    background: var(--color-blockquote-bg);
    color: var(--color-text);
    border-radius: 0 4px 4px 0;
  }
  .docs-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }
  .docs-content :global(a:hover) {
    color: var(--color-accent-dark);
    text-decoration: underline;
  }
  .docs-content :global(ul),
  .docs-content :global(ol) {
    padding-left: 1.75rem;
    margin: 0.5rem 0 1rem;
  }
  .docs-content :global(li) {
    margin: 0.3rem 0;
  }

  .docs-content :global(.admonition) {
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
  }
  .docs-content :global(.admonition > *:last-child) {
    margin-bottom: 0;
  }
  .docs-content :global(.admonition-title) {
    font-weight: 700;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .docs-content :global(.admonition-note) {
    background: #f0f4ff;
    border-left: 4px solid #4a6cf7;
  }
  .docs-content :global(.admonition-note .admonition-title) {
    color: #4a6cf7;
  }
  .docs-content :global(.admonition-info) {
    background: #f0faf8;
    border-left: 4px solid var(--color-accent);
  }
  .docs-content :global(.admonition-info .admonition-title) {
    color: var(--color-accent);
  }
  .docs-content :global(.admonition-tip) {
    background: #f0fdf4;
    border-left: 4px solid #16a34a;
  }
  .docs-content :global(.admonition-tip .admonition-title) {
    color: #16a34a;
  }
  .docs-content :global(.admonition-caution) {
    background: #fffbeb;
    border-left: 4px solid #d97706;
  }
  .docs-content :global(.admonition-caution .admonition-title) {
    color: #d97706;
  }
  .docs-content :global(.admonition-warning) {
    background: #fff1f0;
    border-left: 4px solid #e53e3e;
  }
  .docs-content :global(.admonition-warning .admonition-title) {
    color: #e53e3e;
  }

  /* Figure recipe: the "?" in a figure caption and the dialog it opens.
     Markup comes from src/lib/spec-recipe/html.ts. */
  .docs-content :global(.spec-help) {
    margin-left: 0.5rem;
    width: 1.15rem;
    height: 1.15rem;
    padding: 0;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-style: normal;
    line-height: 1;
    cursor: pointer;
    vertical-align: middle;
  }
  .docs-content :global(.spec-help:hover) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .docs-content :global(.spec-dialog) {
    width: min(46rem, 92vw);
    max-height: 85vh;
    padding: 1.25rem 1.5rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #fff;
    color: var(--color-text);
  }
  .docs-content :global(.spec-dialog::backdrop) {
    background: rgba(0, 0, 0, 0.55);
  }
  .docs-content :global(.spec-dialog-close-form) {
    float: right;
    margin: -0.5rem -0.75rem 0 0;
  }
  .docs-content :global(.spec-dialog-close) {
    border: none;
    background: none;
    color: var(--color-text-muted);
    font-size: 1rem;
    cursor: pointer;
  }
  /* radio-driven tabs: no JS, the checked input selects its panel */
  .docs-content :global(.spec-tab-input) {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .docs-content :global(.spec-tab-label) {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    border-bottom: 2px solid transparent;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-style: normal;
    cursor: pointer;
  }
  .docs-content :global(.spec-tab-input:checked + .spec-tab-label) {
    border-bottom-color: var(--color-accent);
    color: var(--color-accent);
    font-weight: 600;
  }
  .docs-content :global(.spec-tab-input:focus-visible + .spec-tab-label) {
    outline: 2px solid var(--color-accent);
  }
  .docs-content :global(.spec-panel) {
    display: none;
    margin-top: 1rem;
    max-height: 65vh;
    overflow-y: auto;
    text-align: left;
    font-style: normal;
  }
  /* Pairs the nth tab with the nth panel. One rule per panel panels() can emit
     (spec-recipe/html.ts) — a figure with fewer panels just leaves later rules
     unmatched, but a new panel needs a rule here or its tab shows nothing. */
  .docs-content
    :global(
      .spec-tabs > .spec-tab-input:nth-of-type(1):checked ~ .spec-panel-1
    ),
  .docs-content
    :global(
      .spec-tabs > .spec-tab-input:nth-of-type(2):checked ~ .spec-panel-2
    ),
  .docs-content
    :global(
      .spec-tabs > .spec-tab-input:nth-of-type(3):checked ~ .spec-panel-3
    ),
  .docs-content
    :global(
      .spec-tabs > .spec-tab-input:nth-of-type(4):checked ~ .spec-panel-4
    ) {
    display: block;
  }
  .docs-content :global(.spec-intro) {
    margin: 0 0 0.85rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  .docs-content :global(.spec-desktop-open) {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
  }
  .docs-content :global(.spec-steps) {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 0.9rem;
  }
  .docs-content :global(.spec-steps li) {
    margin-bottom: 0.7rem;
  }
  .docs-content :global(.spec-step-title) {
    display: block;
  }
  .docs-content :global(.spec-step-note),
  .docs-content :global(.spec-step-example) {
    display: block;
    margin-top: 0.15rem;
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }
  /* the docs `pre` rule pairs --color-code-text with --color-code-bg; keep both
     together here (a light background with that text color is unreadable) */
  .docs-content :global(.spec-json),
  .docs-content :global(.spec-python) {
    max-height: 45vh;
    overflow: auto;
    padding: 0.75rem;
    border-radius: 4px;
    background: var(--color-code-bg);
    color: var(--color-code-text);
    font-size: 0.8rem;
  }
  .docs-content :global(.spec-config) {
    margin-top: 0.6rem;
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 768px) {
    .docs-content h1 {
      font-size: 1.5rem;
    }
    .docs-content :global(h2) {
      font-size: 1.25rem;
    }
    .docs-content :global(h3) {
      font-size: 1.1rem;
    }
  }
</style>
