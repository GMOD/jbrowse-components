      },
      "displays": [
        {
          "type": "LinearMultiSampleVariantMatrixDisplay",
          "displayId": "hprc2_wave_grch38_matrix",
          "renderingMode": "phased"
        },
        {
          "type": "LinearMultiSampleVariantDisplay",
          "displayId": "hprc2_wave_grch38_regular",
          "renderingMode": "phased"
        }
      ]
    },
    {
      "type": "FeatureTrack",
      "trackId": "hprc2_pclai_painting",
      "name": "HPRC2 local ancestry (PCLAI) \u2014 64 haplotypes, chr1",
      "assemblyNames": ["hg38"],
      "adapter": {
        "type": "BedTabixAdapter",
        "uri": "hprc2_pclai_chr1.bed.gz"
      },
      "displays": [
        {
          "type": "LinearMultiRowFeatureDisplay",
          "displayId": "hprc2_pclai_painting-LinearMultiRowFeatureDisplay",
          "partitionField": "sample",
          "forceLoad": true
        }
      ]
    }
  ],
  "defaultSession": {
