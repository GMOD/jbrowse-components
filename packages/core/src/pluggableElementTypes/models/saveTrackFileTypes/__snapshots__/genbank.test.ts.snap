DEFINITION  chr1:501..600 from testAssembly.
ACCESSION   chr1
VERSION     chr1
KEYWORDS    .
SOURCE      testAssembly
  ORGANISM  testAssembly
            .
FEATURES             Location/Qualifiers
     source          1..100
                     /organism="testAssembly"
                     /mol_type="genomic DNA"
                     /chromosome="chr1"
     gene            complement(1..100)
                     /gene="gene5"
                     /label="gene5"
     mRNA            complement(1..100)
                     /gene="gene5"
                     /label="mrna2"
     CDS             complement(21..80)
                     /gene="gene5"
                     /label="gene5"
                     /codon_start=1
ORIGIN
        1 aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa
       61 aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa
//
"
`;

