exports[`GenBank export handles custom attributes 1`] = `
"LOCUS       chr1_701..800            100 bp    DNA    linear    UNK 10-JAN-1970
DEFINITION  chr1:701..800 from testAssembly.
ACCESSION   chr1
VERSION     chr1
KEYWORDS    .
SOURCE      testAssembly
  ORGANISM  testAssembly
            .
FEATURES             Location/Qualifiers
     source          1..100
                     /organism="testAssembly"
                     /mol_type="genomic DNA"
                     /chromosome="chr1"
     gene            1..100
                     /label="gene6"
                     /custom_tag="custom_value"
                     /another_tag="val1,val2"
                     /complex_obj="{""key"":""value""}"
ORIGIN
        1 aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa
       61 aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa aaaaaaaaaa
//
"
`;

exports[`GenBank export handles features on negative strand 1`] = `
