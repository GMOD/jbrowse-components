    "@mui/material": "^7.0.0",
    "@mui/x-data-grid": "^8.0.0",
    "canvas-sequencer-ts": "^3.1.3",
    "canvas2svg": "^1.0.16",
    "colord": "^2.9.3",
    "copy-to-clipboard": "^3.3.1",
    "deepmerge": "^4.2.2",
    "detect-node": "^2.1.0",
    "dompurify": "^3.3.0",
    "escape-html": "^1.0.3",
