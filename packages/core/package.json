    },
    "./pluggableElementTypes/DisplayType": {
      "import": "./esm/pluggableElementTypes/DisplayType.js",
      "require": "./dist/pluggableElementTypes/DisplayType.js"
    },
    "./pluggableElementTypes/TrackType": {
      "import": "./esm/pluggableElementTypes/TrackType.js",
      "require": "./dist/pluggableElementTypes/TrackType.js"
    },
    "./pluggableElementTypes/WidgetType": {
