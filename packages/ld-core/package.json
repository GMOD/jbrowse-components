{
  "name": "@jbrowse/ld-core",
  "version": "4.3.0",
  "type": "module",
  "description": "Pure linkage-disequilibrium parsers and math — PLINK .ld parsing and genotype r²/D' — no rendering or framework deps",
  "keywords": [
    "jbrowse",
    "jbrowse2",
    "ld",
    "linkage-disequilibrium",
    "plink"
  ],
  "license": "Apache-2.0",
  "homepage": "https://jbrowse.org",
  "bugs": "https://github.com/GMOD/jbrowse-components/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-components.git",
    "directory": "packages/ld-core"
  },
  "author": "JBrowse Team",
  "main": "src/index.ts",
  "files": [
    "esm"
  ],
  "scripts": {
    "build:esm": "tsgo -p tsconfig.build.esm.json",
    "build": "pnpm build:esm",
    "test": "cd ../..; jest --passWithNoTests packages/ld-core",
    "clean": "rimraf esm *.tsbuildinfo",
    "prebuild": "pnpm clean",
    "prepack": "pnpm build"
  },
  "dependencies": {},
  "publishConfig": {
    "access": "public",
    "main": "esm/index.js",
    "types": "esm/index.d.ts",
    "exports": {
      ".": {
        "types": "./esm/index.d.ts",
        "import": "./esm/index.js"
      }
    }
  },
  "sideEffects": false
}
