{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "esnext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": [
    "format.ts",
    "generate.ts",
    "generateApiDocs.ts",
    "generateColorDocs.ts",
    "generateConfigDocs.ts",
    "generateStateModelDocs.ts",
    "util.ts"
  ]
}
