---
import { getCollection } from 'astro:content'
const docs = await getCollection('docs')
const sample = docs.filter(d => d.id.includes('introduction') || d.id.includes('archive') || d.id.includes('pag2026')).concat(docs.slice(0, 5)).map(d => ({
  id: d.id,
  // @ts-ignore
  slug: (d as any).slug,
  data_slug: d.data.slug,
  title: d.data.title,
}))
---
<pre>{JSON.stringify(sample, null, 2)}</pre>
