---
import { getCollection } from 'astro:content'
import { base } from 'astro:config/client'
import BaseLayout from '../../layouts/BaseLayout.astro'
import blog from '../../styles/blog.module.css'
import page from '../../styles/page.module.css'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)
const baseUrl = base.replace(/\/$/, '')

function blogPath(post: (typeof posts)[0]) {
  const stem = post.filePath!.split('/').pop()!.replace(/\.md$/, '')
  const m = stem.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/)!
  return `${m[1]}/${m[2]}/${m[3]}/${m[4]}`
}
---

<BaseLayout title="JBrowse Blog">
  <div class={page.contentNarrow}>
    <h1>Blog</h1>
    {
      posts.map(post => (
        <article>
          <a href={`${baseUrl}/blog/${blogPath(post)}/`}>{post.data.title}</a>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          {post.data.tags && (
            <div class={blog.tags}>
              {post.data.tags.map(tag => (
                <span class={blog.tag}>{tag}</span>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 2rem;
    border-bottom: 1px solid #e0e0e0;
    padding-bottom: 1rem;
  }
  article {
    padding: 1.25rem 0;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  article a {
    font-size: 1.1rem;
    font-weight: 500;
    color: #3f51b5;
    text-decoration: none;
  }
  article a:hover {
    text-decoration: underline;
  }
  time {
    font-size: 0.875rem;
    color: #666;
  }
</style>
