---
import { getCollection } from 'astro:content'
import { baseUrl } from '../../lib/base-url'
import { blogPath } from '../../lib/blog-path'
import BlogLayout from '../../layouts/BlogLayout.astro'
import blog from '../../styles/blog.module.css'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)

const byYear = new Map<string, (typeof posts)>()
for (const post of posts) {
  const year = post.data.date.getFullYear().toString()
  if (!byYear.has(year)) {
    byYear.set(year, [])
  }
  byYear.get(year)!.push(post)
}
const years = [...byYear.keys()].sort((a, b) => Number(b) - Number(a))
---

<BlogLayout title="JBrowse Blog">
  <div class="content">
    <h1>Blog</h1>
    {
      years.map(year => (
        <section>
          <h2>{year}</h2>
          {byYear.get(year)!.map(post => (
            <article>
              <a href={`${baseUrl}/blog/${blogPath(post)}/`}>{post.data.title}</a>
              <div class="article-meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}
                </time>
                {post.data.author && <span class="author">{post.data.author}</span>}
              </div>
              {post.data.tags && (
                <div class={blog.tags}>
                  {post.data.tags.map(tag => (
                    <span class={blog.tag}>{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </section>
      ))
    }
  </div>
</BlogLayout>

<style>
  .content {
    max-width: 800px;
    padding: clamp(1.25rem, 3vw, 2.5rem);
  }
  h1 {
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
  }
  h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 2rem 0 0.5rem;
  }
  article {
    padding: 0.9rem 0;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  article a {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
  }
  article a:hover {
    text-decoration: underline;
  }
  .article-meta {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .author {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
</style>
