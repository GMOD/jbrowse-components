---
import { base } from 'astro:config/client'

interface Props {
  title?: string
}
const { title = 'JBrowse' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href={`${base}img/favicon.ico`} />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto&display=swap"
    />
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: 'Roboto', sans-serif;
      }
      nav.site-nav {
        background: #0d223f;
        display: flex;
        align-items: center;
        padding: 0 1rem;
        height: 60px;
        gap: 1.5rem;
      }
      nav.site-nav .brand {
        color: white;
        font-size: 1.2rem;
        font-weight: bold;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      nav.site-nav .brand img {
        height: 32px;
      }
      nav.site-nav a {
        color: white;
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.2s;
      }
      nav.site-nav a:hover {
        color: #46cbae;
      }
      nav.site-nav .new-feature::after {
        content: 'NEW!';
        font-size: 0.6em;
        font-weight: bold;
        color: red;
        margin-left: 4px;
        vertical-align: super;
      }
      nav.site-nav .right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      nav.site-nav .github-icon {
        width: 24px;
        height: 24px;
        display: block;
        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='white' d='M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: center;
        transition: opacity 0.2s;
      }
      nav.site-nav .github-icon:hover {
        filter: invert(62%) sepia(57%) saturate(419%) hue-rotate(117deg) brightness(101%) contrast(87%);
      }
      footer.site-footer {
        background: #0d223f;
        color: #ccc;
        text-align: center;
        padding: 1.5rem;
        font-size: 0.85rem;
        margin-top: 4rem;
      }
    </style>
  </head>
  <body>
    <nav class="site-nav">
      <a class="brand" href={`${base}/`}>
        <img src={`${base}/img/logo.svg`} alt="JBrowse" />
        JBrowse
      </a>
      <a href="http://genomes.jbrowse.org/" class="new-feature">Genomes</a>
      <a href={`${base}/docs/`}>Docs</a>
      <a href={`${base}/blog/`}>Blog</a>
      <a href={`${base}/download/`}>Download</a>
      <a href={`${base}/plugin_store/`}>Plugins</a>
      <a href={`${base}/features/`}>Features</a>
      <a href={`${base}/gallery/`}>Gallery</a>
      <a href={`${base}/demos/`}>Demos</a>
      <a href={`${base}/contact/`}>Contact</a>
      <div class="right">
        <a href="https://jbrowse.org/jbrowse1.html" style="white-space:nowrap">
          Looking for JBrowse 1?
        </a>
        <a
          href="https://github.com/GMOD/jbrowse-components"
          class="github-icon"
          aria-label="GitHub"
        ></a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      Copyright © {new Date().getFullYear()} The JBrowse Consortium
    </footer>
  </body>
</html>
