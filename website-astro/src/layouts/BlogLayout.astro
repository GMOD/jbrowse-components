---
import { getCollection } from 'astro:content'
import { baseUrl } from '../lib/base-url'
import { blogPath } from '../lib/blog-path'
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  currentSlug?: string
}

const { title, currentSlug = '' } = Astro.props

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)

const byYear = new Map<string, { slug: string; title: string; href: string }[]>()
for (const post of posts) {
  const slug = blogPath(post)
  const year = slug.split('/')[0]
  if (!byYear.has(year)) {
    byYear.set(year, [])
  }
  byYear.get(year)!.push({ slug, title: post.data.title, href: `${baseUrl}/blog/${slug}/` })
}

const years = [...byYear.keys()].sort((a, b) => Number(b) - Number(a))
const currentYear = currentSlug ? currentSlug.split('/')[0] : ''
---

<BaseLayout title={title}>
  <div class="blog-layout">
    <nav class="blog-sidebar" aria-label="Blog navigation">
      <ul>
        <li>
          <a
            href={`${baseUrl}/blog/`}
            class:list={[{ active: !currentSlug }]}
            aria-current={!currentSlug ? 'page' : undefined}
          >
            All posts
          </a>
        </li>
        {
          years.map(year => (
            <li>
              <details open={year === currentYear || (!currentSlug && year === years[0]) || undefined}>
                <summary>{year}</summary>
                <ul>
                  {byYear.get(year)!.map(post => (
                    <li>
                      <a
                        href={post.href}
                        class:list={[{ active: post.slug === currentSlug }]}
                        aria-current={post.slug === currentSlug ? 'page' : undefined}
                      >
                        {post.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="blog-content">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .blog-layout {
    display: flex;
    min-height: calc(100vh - var(--nav-height));
  }

  .blog-sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    padding: 1rem 0;
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
  }

  .blog-sidebar ul {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1rem;
  }
  .blog-sidebar > ul {
    padding: 0;
  }

  .blog-sidebar a {
    display: block;
    padding: var(--sidebar-link-padding);
    color: var(--color-sidebar-text);
    text-decoration: none;
    font-size: 0.9rem;
    border-radius: 3px;
    transition: background 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .blog-sidebar a:hover {
    background: var(--color-sidebar-hover-bg);
    color: var(--color-navy);
  }
  .blog-sidebar a.active {
    background: var(--color-sidebar-active-bg);
    color: var(--color-sidebar-active-text);
    font-weight: 500;
  }

  .blog-sidebar details > summary {
    cursor: pointer;
    padding: var(--sidebar-link-padding);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    list-style: none;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 0.5em;
    border-radius: 3px;
    transition: background 0.15s;
  }
  .blog-sidebar details > summary:hover {
    background: var(--color-sidebar-hover-bg);
  }
  .blog-sidebar details > summary::-webkit-details-marker {
    display: none;
  }
  .blog-sidebar details > summary::before {
    content: '';
    display: inline-block;
    flex-shrink: 0;
    width: 0.4em;
    height: 0.4em;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(-45deg);
    transition: transform 0.15s ease;
    opacity: 0.6;
  }
  .blog-sidebar details[open] > summary::before {
    transform: rotate(45deg);
  }

  .blog-content {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .blog-layout {
      flex-direction: column;
    }
    .blog-sidebar {
      width: 100%;
      height: auto;
      position: static;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      max-height: 300px;
    }
  }
</style>

<script>
  document.querySelector('.blog-sidebar [aria-current="page"]')?.scrollIntoView({ block: 'nearest' })
</script>
