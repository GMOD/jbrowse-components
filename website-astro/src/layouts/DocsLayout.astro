---
import type { MarkdownHeading } from 'astro'
import { getCollection } from 'astro:content'
import { baseUrl } from '../lib/base-url'
import BaseLayout from './BaseLayout.astro'
import SidebarItem from '../components/SidebarItem.astro'
import { buildSidebar } from '../lib/docs-sidebar'

interface Props {
  title: string
  currentSlug: string
  description?: string
  headings?: MarkdownHeading[]
}

const { title, currentSlug, description, headings = [] } = Astro.props

const allDocs = await getCollection('docs')
const sidebar = buildSidebar(allDocs, baseUrl)

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3)
---

<BaseLayout title={`${title} | JBrowse Docs`} description={description}>
  <div class="docs-layout">
    <nav class="docs-sidebar" aria-label="Documentation navigation">
      <ul>
        {sidebar.map(item => (
          <SidebarItem item={item} currentSlug={currentSlug} depth={0} />
        ))}
      </ul>
    </nav>
    <article class="docs-content" data-pagefind-body>
      <h1>{title}</h1>
      <slot />
    </article>
    {tocHeadings.length > 1 && (
      <aside class="docs-toc" aria-label="On this page">
        <p class="toc-label">On this page</p>
        <ul>
          {tocHeadings.map(h => (
            <li class={h.depth === 3 ? 'toc-h3' : ''}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .docs-layout {
    display: flex;
    min-height: calc(100vh - var(--nav-height));
  }

  .docs-sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    padding: 1rem 0;
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
  }

  .docs-sidebar :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1rem;
  }
  .docs-sidebar > :global(ul) {
    padding: 0;
  }

  .docs-sidebar :global(a) {
    display: block;
    padding: var(--sidebar-link-padding);
    color: var(--color-sidebar-text);
    text-decoration: none;
    font-size: 1rem;
    border-radius: 3px;
    transition: background 0.15s;
  }
  .docs-sidebar :global(a:hover) {
    background: var(--color-sidebar-hover-bg);
    color: var(--color-navy);
  }
  .docs-sidebar :global(a.active) {
    background: var(--color-sidebar-active-bg);
    color: var(--color-sidebar-active-text);
    font-weight: 500;
  }

  .docs-sidebar :global(details > summary) {
    cursor: pointer;
    padding: var(--sidebar-link-padding);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-sidebar-text);
    list-style: none;
    user-select: none;
  }
  .docs-sidebar :global(details > summary::-webkit-details-marker) {
    display: none;
  }
  .docs-sidebar :global(details > summary::before) {
    content: '▶ ';
    font-size: 0.65em;
    opacity: 0.6;
  }
  .docs-sidebar :global(details[open] > summary::before) {
    content: '▼ ';
  }

  .docs-content {
    flex: 1;
    max-width: 860px;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    min-width: 0;
    line-height: 1.7;
  }

  .docs-content h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .docs-content :global(h2) {
    font-size: 2rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .docs-content :global(h3) { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; color: var(--color-text); }
  .docs-content :global(h4) { font-size: 1.125rem; font-weight: 700; margin-top: 1.5rem; color: var(--color-text); }

  .docs-content :global(h2),
  .docs-content :global(h3),
  .docs-content :global(h4) {
    position: relative;
  }
  .docs-content :global(.heading-anchor) {
    opacity: 0;
    margin-left: 0.4rem;
    font-size: 0.8em;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none !important;
    transition: opacity 0.15s;
  }
  .docs-content :global(h2:hover .heading-anchor),
  .docs-content :global(h3:hover .heading-anchor),
  .docs-content :global(h4:hover .heading-anchor) {
    opacity: 1;
  }

  .docs-content :global(pre) {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 1rem 1.25rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 1rem 0;
  }
  .docs-content :global(code:not(pre code)) {
    background: #f0f0f0;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.875em;
    color: #c7254e;
  }
  .docs-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1rem auto;
    border-radius: 4px;
    border: 1px solid #ddd;
  }
  .docs-content :global(figure) {
    border: 1px solid #ccc;
    border-radius: 6px;
    padding: 1rem;
    margin: 1.5rem 0;
    background: #fafafa;
  }
  .docs-content :global(figcaption) {
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }
  .docs-content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
    overflow-x: auto;
    display: block;
  }
  .docs-content :global(th),
  .docs-content :global(td) {
    border: 1px solid #ddd;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .docs-content :global(th) { background: var(--color-surface); font-weight: 600; }
  .docs-content :global(tr:nth-child(even)) { background: #fafafa; }
  .docs-content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    margin: 1.5rem 0;
    padding: 0.5rem 1.25rem;
    background: #f0faf8;
    color: var(--color-text);
    border-radius: 0 4px 4px 0;
  }
  .docs-content :global(a) {
    text-decoration: none;
  }
  .docs-content :global(a:hover) {
    text-decoration: underline;
  }
  .docs-content :global(ul),
  .docs-content :global(ol) {
    padding-left: 1.75rem;
    margin: 0.5rem 0 1rem;
  }
  .docs-content :global(li) {
    margin: 0.3rem 0;
  }

  .docs-content :global(.admonition) {
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
  }
  .docs-content :global(.admonition > *:last-child) { margin-bottom: 0; }
  .docs-content :global(.admonition-title) {
    font-weight: 700;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .docs-content :global(.admonition-note) {
    background: #f0f4ff;
    border-left: 4px solid #4a6cf7;
  }
  .docs-content :global(.admonition-note .admonition-title) { color: #4a6cf7; }
  .docs-content :global(.admonition-info) {
    background: #f0faf8;
    border-left: 4px solid var(--color-accent);
  }
  .docs-content :global(.admonition-info .admonition-title) { color: var(--color-accent); }
  .docs-content :global(.admonition-caution) {
    background: #fffbeb;
    border-left: 4px solid #d97706;
  }
  .docs-content :global(.admonition-caution .admonition-title) { color: #d97706; }
  .docs-content :global(.admonition-warning) {
    background: #fff1f0;
    border-left: 4px solid #e53e3e;
  }
  .docs-content :global(.admonition-warning .admonition-title) { color: #e53e3e; }

  /* ── Table of contents ── */
  .docs-toc {
    display: none;
    width: 220px;
    flex-shrink: 0;
    padding: 2rem 1rem 2rem 0.5rem;
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
  }
  .toc-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 0.6rem;
  }
  .docs-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .docs-toc li {
    margin: 0;
  }
  .docs-toc a {
    display: block;
    padding: 0.25rem 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    line-height: 1.4;
  }
  .docs-toc a:hover {
    color: var(--color-navy);
    border-left-color: var(--color-accent);
    text-decoration: none !important;
  }
  .docs-toc .toc-h3 a {
    padding-left: 1.25rem;
  }

  @media (min-width: 1280px) {
    .docs-toc { display: block; }
  }

  @media (max-width: 768px) {
    .docs-layout { flex-direction: column; }
    .docs-sidebar {
      width: 100%;
      height: auto;
      position: static;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      max-height: 300px;
    }
  }
</style>
