---
import { getCollection } from 'astro:content'
import { baseUrl } from '../lib/base-url'
import BaseLayout from './BaseLayout.astro'
import SidebarItem from '../components/SidebarItem.astro'
import { buildSidebar } from '../lib/docs-sidebar'

interface Props {
  title: string
  currentSlug: string
  description?: string
}

const { title, currentSlug, description } = Astro.props

const allDocs = await getCollection('docs')
const sidebar = buildSidebar(allDocs, baseUrl)

---

<BaseLayout title={`${title} | JBrowse Docs`} description={description}>
  <div class="docs-layout">
    <nav class="docs-sidebar" aria-label="Documentation navigation">
      <ul>
        {sidebar.map(item => (
          <SidebarItem item={item} currentSlug={currentSlug} />
        ))}
      </ul>
    </nav>
    <article class="docs-content" data-pagefind-body>
      <h1>{title}</h1>
      <slot />
    </article>
  </div>
</BaseLayout>

<script>
  const sidebar = document.querySelector('.docs-sidebar')
  const active = sidebar?.querySelector('a[aria-current="page"]')
  if (active) {
    let el: HTMLElement | null = active.parentElement
    while (el && el !== sidebar) {
      if (el.tagName === 'DETAILS') {
        (el as HTMLDetailsElement).open = true
      }
      el = el.parentElement
    }
  }
  sidebar?.querySelector('a[aria-current="page"]')?.scrollIntoView({ block: 'nearest' })
</script>

<style>
  .docs-layout {
    display: flex;
    min-height: calc(100vh - var(--nav-height));
  }

  .docs-sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    padding: 1rem 0;
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
  }

  .docs-sidebar :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1rem;
  }
  .docs-sidebar > :global(ul) {
    padding: 0;
  }

  .docs-sidebar :global(a) {
    display: block;
    padding: var(--sidebar-link-padding);
    color: var(--color-sidebar-text);
    text-decoration: none;
    font-size: 1rem;
    border-radius: 3px;
    transition: background 0.15s;
  }
  .docs-sidebar :global(a:hover) {
    background: var(--color-sidebar-hover-bg);
    color: var(--color-navy);
  }
  .docs-sidebar :global(a.active) {
    background: var(--color-sidebar-active-bg);
    color: var(--color-sidebar-active-text);
    font-weight: 600;
    border-left: 3px solid var(--color-accent);
    padding-left: calc(12px - 3px);
  }

  .docs-sidebar :global(details > summary) {
    cursor: pointer;
    padding: var(--sidebar-link-padding);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-sidebar-text);
    list-style: none;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 0.5em;
    border-radius: 3px;
    transition: background 0.15s;
  }
  .docs-sidebar :global(details > summary:hover) {
    background: var(--color-sidebar-hover-bg);
    color: var(--color-navy);
  }
  .docs-sidebar :global(details > summary::-webkit-details-marker) {
    display: none;
  }
  .docs-sidebar :global(details > summary::before) {
    content: '';
    display: inline-block;
    flex-shrink: 0;
    width: 0.4em;
    height: 0.4em;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(-45deg);
    transition: transform 0.15s ease;
    opacity: 0.7;
  }
  .docs-sidebar :global(details[open] > summary::before) {
    transform: rotate(45deg);
  }

  .docs-content {
    flex: 1;
    max-width: 1060px;
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    min-width: 0;
    line-height: 1.7;
  }

  .docs-content h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .docs-content :global(h2) {
    font-size: 2rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .docs-content :global(h3) { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; color: var(--color-text); }
  .docs-content :global(h4) { font-size: 1.125rem; font-weight: 700; margin-top: 1.5rem; color: var(--color-text); }

  .docs-content :global(h2),
  .docs-content :global(h3),
  .docs-content :global(h4) {
    position: relative;
  }
  .docs-content :global(.heading-anchor) {
    opacity: 0;
    margin-left: 0.4rem;
    font-size: 0.8em;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none !important;
    transition: opacity 0.15s;
  }
  .docs-content :global(h2:hover .heading-anchor),
  .docs-content :global(h3:hover .heading-anchor),
  .docs-content :global(h4:hover .heading-anchor) {
    opacity: 1;
  }

  .docs-content :global(pre) {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 1rem 1.25rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 1rem 0;
  }
  .docs-content :global(code:not(pre code)) {
    background: #f0f0f0;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.875em;
    color: #c7254e;
  }
  .docs-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1rem auto;
    border-radius: 4px;
    border: 1px solid #ddd;
  }
  .docs-content :global(figure) {
    border: 1px solid #ccc;
    border-radius: 6px;
    padding: 1rem;
    margin: 1.5rem 0;
    background: #fafafa;
  }
  .docs-content :global(figcaption) {
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }
  .docs-content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
    overflow-x: auto;
    display: block;
  }
  .docs-content :global(th),
  .docs-content :global(td) {
    border: 1px solid #ddd;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .docs-content :global(th) { background: var(--color-surface); font-weight: 600; }
  .docs-content :global(tr:nth-child(even)) { background: #fafafa; }
  .docs-content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    margin: 1.5rem 0;
    padding: 0.5rem 1.25rem;
    background: #f0faf8;
    color: var(--color-text);
    border-radius: 0 4px 4px 0;
  }
  .docs-content :global(a) {
    color: var(--color-primary);
    text-decoration: none;
  }
  .docs-content :global(a:hover) {
    text-decoration: underline;
  }
  .docs-content :global(ul),
  .docs-content :global(ol) {
    padding-left: 1.75rem;
    margin: 0.5rem 0 1rem;
  }
  .docs-content :global(li) {
    margin: 0.3rem 0;
  }

  .docs-content :global(.admonition) {
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
  }
  .docs-content :global(.admonition > *:last-child) { margin-bottom: 0; }
  .docs-content :global(.admonition-title) {
    font-weight: 700;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .docs-content :global(.admonition-note) {
    background: #f0f4ff;
    border-left: 4px solid #4a6cf7;
  }
  .docs-content :global(.admonition-note .admonition-title) { color: #4a6cf7; }
  .docs-content :global(.admonition-info) {
    background: #f0faf8;
    border-left: 4px solid var(--color-accent);
  }
  .docs-content :global(.admonition-info .admonition-title) { color: var(--color-accent); }
  .docs-content :global(.admonition-caution) {
    background: #fffbeb;
    border-left: 4px solid #d97706;
  }
  .docs-content :global(.admonition-caution .admonition-title) { color: #d97706; }
  .docs-content :global(.admonition-warning) {
    background: #fff1f0;
    border-left: 4px solid #e53e3e;
  }
  .docs-content :global(.admonition-warning .admonition-title) { color: #e53e3e; }

  @media (max-width: 768px) {
    .docs-layout { flex-direction: column; }
    .docs-sidebar {
      width: 100%;
      height: auto;
      position: static;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      max-height: 300px;
    }
  }
</style>
