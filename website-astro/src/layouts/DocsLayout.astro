---
import { getCollection } from 'astro:content'
import { baseUrl } from '../lib/base-url'
import BaseLayout from './BaseLayout.astro'
import SidebarItem from '../components/SidebarItem.astro'
import { buildSidebar } from '../lib/docs-sidebar'

interface Props {
  title: string
  currentSlug: string
  description?: string
}

const { title, currentSlug, description } = Astro.props

const allDocs = await getCollection('docs')
const sidebar = buildSidebar(allDocs, baseUrl)
---

<BaseLayout title={`${title} | JBrowse Docs`} description={description}>
  <div class="docs-layout">
    <nav class="docs-sidebar" aria-label="Documentation navigation">
      <ul>
        {sidebar.map(item => (
          <SidebarItem item={item} currentSlug={currentSlug} depth={0} />
        ))}
      </ul>
    </nav>
    <article class="docs-content">
      <h1>{title}</h1>
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .docs-layout {
    display: flex;
    min-height: calc(100vh - 60px);
  }

  .docs-sidebar {
    width: 280px;
    flex-shrink: 0;
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    padding: 1rem 0;
    position: sticky;
    top: 60px;
    height: calc(100vh - 60px);
  }

  .docs-sidebar :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1rem;
  }
  .docs-sidebar > :global(ul) {
    padding: 0;
  }

  .docs-sidebar :global(a) {
    display: block;
    padding: 0.3rem 1rem;
    color: #333;
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: 3px;
    transition: background 0.15s;
  }
  .docs-sidebar :global(a:hover) {
    background: #e8e8e8;
    color: var(--color-navy);
  }
  .docs-sidebar :global(a.active) {
    background: var(--color-sidebar-active-bg);
    color: var(--color-sidebar-active-text);
    font-weight: 600;
  }

  .docs-sidebar :global(details > summary) {
    cursor: pointer;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #555;
    list-style: none;
    user-select: none;
  }
  .docs-sidebar :global(details > summary::-webkit-details-marker) {
    display: none;
  }
  .docs-sidebar :global(details > summary::before) {
    content: '▶ ';
    font-size: 0.65em;
    opacity: 0.6;
  }
  .docs-sidebar :global(details[open] > summary::before) {
    content: '▼ ';
  }

  .docs-content {
    flex: 1;
    max-width: 860px;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    min-width: 0;
    line-height: 1.7;
  }

  .docs-content h1 {
    font-size: 2rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: #0d223f;
    border-bottom: 2px solid #e0e0e0;
    padding-bottom: 0.75rem;
  }

  .docs-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    color: #0d223f;
    border-bottom: 1px solid #e8e8e8;
    padding-bottom: 0.4rem;
  }
  .docs-content :global(h3) { font-size: 1.2rem; margin-top: 1.5rem; color: #1a3a6a; }
  .docs-content :global(h4) { font-size: 1rem; margin-top: 1.2rem; color: #333; }

  .docs-content :global(pre) {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 1rem 1.25rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 1rem 0;
  }
  .docs-content :global(code:not(pre code)) {
    background: #f0f0f0;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.875em;
    color: #c7254e;
  }
  .docs-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1rem auto;
    border-radius: 4px;
    border: 1px solid #ddd;
  }
  .docs-content :global(figure) {
    border: 1px solid #ccc;
    border-radius: 6px;
    padding: 1rem;
    margin: 1.5rem 0;
    background: #fafafa;
  }
  .docs-content :global(figcaption) {
    text-align: center;
    font-style: italic;
    color: #666;
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }
  .docs-content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
    overflow-x: auto;
    display: block;
  }
  .docs-content :global(th),
  .docs-content :global(td) {
    border: 1px solid #ddd;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .docs-content :global(th) { background: #f0f4f8; font-weight: 600; }
  .docs-content :global(tr:nth-child(even)) { background: #fafafa; }
  .docs-content :global(blockquote) {
    border-left: 4px solid #25c2a0;
    margin: 1.5rem 0;
    padding: 0.5rem 1.25rem;
    background: #f0faf8;
    color: #333;
    border-radius: 0 4px 4px 0;
  }
  .docs-content :global(a) {
    text-decoration: none;
  }
  .docs-content :global(a:hover) {
    text-decoration: underline;
  }
  .docs-content :global(ul),
  .docs-content :global(ol) {
    padding-left: 1.75rem;
    margin: 0.5rem 0 1rem;
  }
  .docs-content :global(li) {
    margin: 0.3rem 0;
  }

  @media (max-width: 768px) {
    .docs-layout { flex-direction: column; }
    .docs-sidebar {
      width: 100%;
      height: auto;
      position: static;
      border-right: none;
      border-bottom: 1px solid #e0e0e0;
      max-height: 300px;
    }
  }
</style>
