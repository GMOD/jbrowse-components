---
import type { SidebarItem } from '../lib/docs-sidebar'
import SidebarItem from './SidebarItem.astro'

interface Props {
  item: SidebarItem
  currentSlug: string
  depth: number
}
const { item, currentSlug, depth } = Astro.props
---

{item.type === 'link' ? (
  <li>
    <a
      href={item.href}
      class:list={[{ active: item.slug === currentSlug }]}
      aria-current={item.slug === currentSlug ? 'page' : undefined}
    >
      {item.label}
    </a>
  </li>
) : (
  <li>
    <details open={depth === 0 || undefined}>
      <summary>{item.label}</summary>
      <ul>
        {item.items.map(child => (
          <SidebarItem item={child} currentSlug={currentSlug} depth={depth + 1} />
        ))}
      </ul>
    </details>
  </li>
)}
