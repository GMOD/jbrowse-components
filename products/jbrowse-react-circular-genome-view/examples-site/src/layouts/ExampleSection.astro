---
import { Code } from 'astro:components'

import { demoFillHeight } from '../siteMeta.ts'

import type { MarkdownInstance } from 'astro'

// One live demo within an example page: optional heading + description (only
// shown when a page stacks several sections), the hand-written doc from
// src/docs/<slug>.md, the live demo (slotted in), and its collapsible source.
interface Props {
  slug: string
  title?: string
  description?: string
  code: string
}

const { slug, title, description, code } = Astro.props

const docs = import.meta.glob<MarkdownInstance<Record<string, unknown>>>(
  '../docs/*.md',
)
const loader = docs[`../docs/${slug}.md`]
const doc = loader ? await loader() : undefined
const Doc = doc?.Content
---

<section id={slug} class="example-section">
  {title && <h2>{title}</h2>}
  {description && <p class="lead">{description}</p>}
  {
    Doc && (
      <div class="doc">
        <Doc />
      </div>
    )
  }
  <div class:list={['demo', { fill: demoFillHeight }]}><slot /></div>
  <details class="source">
    <summary>View source</summary>
    <Code code={code} lang="tsx" />
  </details>
</section>
