---
import { Code } from 'astro:components'

import type { MarkdownInstance } from 'astro'

import Shell from './Shell.astro'
import { examples } from '../examples.ts'
import { componentLabel, mainMaxWidth } from '../siteMeta.ts'

interface Props {
  slug: string
  title: string
  description?: string
  code: string
}

const { slug, title, description, code } = Astro.props

// each example page may have a hand-written doc at src/docs/<slug>.md; render it
// above the live demo when present
const docs = import.meta.glob<MarkdownInstance<Record<string, unknown>>>(
  '../docs/*.md',
)
const loader = docs[`../docs/${slug}.md`]
const doc = loader ? await loader() : undefined
const Doc = doc?.Content
---

<Shell
  title={title}
  componentLabel={componentLabel}
  examples={examples}
  mainMaxWidth={mainMaxWidth}
>
  <style is:global>
    .lead {
      font-size: 1.05em;
      color: var(--muted);
    }
    .doc h2 {
      margin-top: 28px;
      border-bottom: 1px solid #eee;
      padding-bottom: 4px;
    }
    .doc h3 {
      margin-top: 20px;
    }
    .doc code {
      background: #f4f4f4;
      padding: 1px 4px;
      border-radius: 3px;
      font-size: 0.9em;
    }
    .doc pre code {
      background: none;
      padding: 0;
    }
    .demo {
      border: 1px solid var(--border);
      border-radius: 4px;
      margin-bottom: 16px;
    }
    details.source {
      border: 1px solid var(--border);
      border-radius: 4px;
      margin-bottom: 24px;
    }
    details.source > summary {
      cursor: pointer;
      padding: 8px 12px;
      font-weight: 600;
      user-select: none;
    }
    details.source[open] > summary {
      border-bottom: 1px solid var(--border);
    }
    details.source pre {
      padding: 16px;
      border-radius: 0 0 4px 4px;
      overflow: auto;
      margin: 0;
    }
  </style>
  <h1>{title}</h1>
  {description && <p class="lead">{description}</p>}
  {Doc && <div class="doc"><Doc /></div>}
  <h2>Live demo</h2>
  <div class="demo"><slot /></div>
  <details class="source">
    <summary>View source</summary>
    <Code code={code} lang="tsx" />
  </details>
</Shell>
