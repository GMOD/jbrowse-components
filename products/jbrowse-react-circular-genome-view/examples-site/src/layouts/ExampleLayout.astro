---
import { Code } from 'astro:components'

interface Props {
  title: string
  description?: string
  code: string
}

const { title, description, code } = Astro.props
const base = import.meta.env.BASE_URL
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} — JBrowse Circular Genome View examples</title>
    <style is:global>
      body {
        margin: 0;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica,
          Arial, sans-serif;
        color: #1a1a1a;
      }
      header {
        padding: 8px 16px;
        border-bottom: 1px solid #ddd;
        background: #fafafa;
      }
      header a {
        color: #135ba8;
        text-decoration: none;
      }
      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px;
      }
      h1 {
        margin-top: 0;
      }
      .demo {
        border: 1px solid #ddd;
        border-radius: 4px;
        margin-bottom: 24px;
      }
      pre {
        padding: 16px;
        border-radius: 4px;
        overflow: auto;
      }
    </style>
  </head>
  <body>
    <header><a href={base}>← All examples</a></header>
    <main>
      <h1>{title}</h1>
      {description && <p>{description}</p>}
      <div class="demo"><slot /></div>
      <h2>Source</h2>
      <Code code={code} lang="tsx" />
    </main>
  </body>
</html>
