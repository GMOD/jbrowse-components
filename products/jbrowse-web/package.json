{
  "name": "@jbrowse/web",
  "version": "4.2.1",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": ".",
  "main": "build",
  "dir": "src",
  "exports": {
    "./src/rootModel/index.js": "./src/rootModel/index.ts",
    "./src/makeWorkerInstance": "./src/makeWorkerInstance.ts"
  },
  "scripts": {
    "start": "node scripts/start.ts",
    "build": "node scripts/build.ts",
    "prebuild": "rimraf build",
    "postbuild": "node -e \"fs.writeFileSync('build/version.txt',JSON.parse(require('fs').readFileSync('package.json', 'utf8')).version)\"",
    "prepack": "pnpm build",
    "test:browser": "node browser-tests/runner.ts",
    "test:browser:headed": "node browser-tests/runner.ts --headed",
    "test:browser:update": "node browser-tests/runner.ts --update-snapshots",
    "test:browser:webgl": "node browser-tests/runner.ts --backend=webgl",
    "test:browser:canvas2d": "node browser-tests/runner.ts --backend=canvas2d",
    "test:browser:webgpu": "VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/lvp_icd.json xvfb-run --auto-servernum node browser-tests/runner.ts --backend=webgpu",
    "test:browser:webgpu:firefox": "VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/lvp_icd.json xvfb-run --auto-servernum node browser-tests/runner.ts --backend=webgpu --firefox",
    "test:browser:all-backends": "VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/lvp_icd.json xvfb-run --auto-servernum node browser-tests/runner.ts --backend=all -u",
    "test:browser:all-backends:ci": "node browser-tests/runner.ts --backend=all --skip-webgpu -u",
    "test:browser:compare": "node browser-tests/compare-backends.ts"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@jbrowse/app-core": "workspace:^",
    "@jbrowse/core": "workspace:^",
    "@jbrowse/mobx-state-tree": "^5.6.0",
    "@jbrowse/plugin-alignments": "workspace:^",
    "@jbrowse/plugin-arc": "workspace:^",
    "@jbrowse/plugin-authentication": "workspace:^",
    "@jbrowse/plugin-bed": "workspace:^",
    "@jbrowse/plugin-breakpoint-split-view": "workspace:^",
    "@jbrowse/plugin-canvas": "workspace:^",
    "@jbrowse/plugin-circular-view": "workspace:^",
    "@jbrowse/plugin-comparative-adapters": "workspace:^",
    "@jbrowse/plugin-config": "workspace:^",
    "@jbrowse/plugin-data-management": "workspace:^",
    "@jbrowse/plugin-dotplot-view": "workspace:^",
    "@jbrowse/plugin-gccontent": "workspace:^",
    "@jbrowse/plugin-gff3": "workspace:^",
    "@jbrowse/plugin-graph": "workspace:^",
    "@jbrowse/plugin-grid-bookmark": "workspace:^",
    "@jbrowse/plugin-gtf": "workspace:^",
    "@jbrowse/plugin-hic": "workspace:^",
    "@jbrowse/plugin-jobs-management": "workspace:^",
    "@jbrowse/plugin-legacy-jbrowse": "workspace:^",
    "@jbrowse/plugin-linear-comparative-view": "workspace:^",
    "@jbrowse/plugin-linear-genome-view": "workspace:^",
    "@jbrowse/plugin-lollipop": "workspace:^",
