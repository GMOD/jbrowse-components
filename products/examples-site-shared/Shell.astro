---
// Shared chrome for every product's examples-site (lgv / cgv / app). Each site
// symlinks src/layouts/Shell.astro to this file, so it must stay self-contained
// — NO relative imports (`astro check` resolves them from the symlink's own
// directory, not this file's real path, so they fail). All site-specific data
// arrives via props; the example shape is inlined for the same reason.
interface ExampleMeta {
  slug: string
  title: string
  group: string
}

interface Props {
  title: string
  componentLabel: string
  examples: ExampleMeta[]
  mainMaxWidth?: string
}

const { title, componentLabel, examples, mainMaxWidth = '920px' } = Astro.props
const base = import.meta.env.BASE_URL
const docsHref = 'https://jbrowse.org/jb2/docs/embedded_components/'

// the three sibling examples-sites, cross-linked so a reader who lands on the
// wrong component can hop. the current one is matched off BASE_URL rather than
// threaded in as a prop, so adding a site here lights it up everywhere
const siblings = [
  { label: 'LGV', base: '/storybook/lgv/', title: 'Linear Genome View' },
  { label: 'CGV', base: '/storybook/cgv/', title: 'Circular Genome View' },
  { label: 'App', base: '/storybook/app/', title: 'Full React App' },
]
const withSlash = (s: string) => (s.endsWith('/') ? s : `${s}/`)
const isSelf = (b: string) => withSlash(base) === b

// highlight the current example in the sidebar by matching the URL, so pages
// don't need to thread their slug through
const trimSlash = (s: string) => s.replace(/\/+$/, '')
const here = trimSlash(Astro.url.pathname)
const isActive = (slug: string) => trimSlash(`${base}${slug}`) === here

// sidebar is grouped by each page's `group`, in first-appearance order (the
// pages list is already group-contiguous), mirroring the index Gallery
const groups = [...new Set(examples.map(e => e.group))]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <title>{title} — JBrowse {componentLabel}</title>
    {/* apply the saved theme before first paint to avoid a flash */}
    <script is:inline>
      const saved = localStorage.getItem('jb-theme')
      if (saved === 'dark' || saved === 'light') {
        document.documentElement.dataset.theme = saved
      }
    </script>
    <style is:global>
      :root {
        --accent: #135ba8;
        --accent-fg: #ffffff;
        --bg: #ffffff;
        --fg: #1a1a1a;
        --fg-soft: #333333;
        --muted: #5a5a5a;
        --border: #e2e2e2;
        --rule: #eeeeee;
        --hover: #f1f5fa;
        --card-hover: #f5f9fd;
        --code-inline-bg: #f4f4f4;
        --sidebar-width: 260px;
        --topbar-h: 53px;
      }
      /* dark palette: explicit toggle wins; otherwise follow the OS setting */
      :root[data-theme='dark'] {
        --accent: #6db3f2;
        --accent-fg: #10151b;
        --bg: #16191d;
        --fg: #e4e6e8;
        --fg-soft: #c6c9cd;
        --muted: #9aa0a6;
        --border: #2c3138;
        --rule: #262b31;
        --hover: #1e242b;
        --card-hover: #1e242b;
        --code-inline-bg: #23282f;
      }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme='light']) {
          --accent: #6db3f2;
          --accent-fg: #10151b;
          --bg: #16191d;
          --fg: #e4e6e8;
          --fg-soft: #c6c9cd;
          --muted: #9aa0a6;
          --border: #2c3138;
          --rule: #262b31;
          --hover: #1e242b;
          --card-hover: #1e242b;
          --code-inline-bg: #23282f;
        }
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica,
          Arial, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.55;
      }
      a {
        color: var(--accent);
      }
      header.topbar {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 10px 20px;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
      }
      header.topbar .brand {
        font-weight: 700;
        color: var(--fg);
        text-decoration: none;
        font-size: 1.05em;
      }
      header.topbar .brand span {
        color: var(--muted);
        font-weight: 400;
      }
      header.topbar nav {
        display: flex;
        align-items: center;
        gap: 18px;
        font-size: 0.92em;
      }
      header.topbar nav a {
        text-decoration: none;
      }
      header.topbar nav a:hover {
        text-decoration: underline;
      }
      /* segmented lgv / cgv / app switcher */
      .siblings {
        display: inline-flex;
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
      }
      .sibling {
        padding: 3px 10px;
        font-size: 0.9em;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
      }
      .sibling + .sibling {
        border-left: 1px solid var(--border);
      }
      .sibling.current {
        color: var(--accent-fg);
        background: var(--accent);
      }
      header.topbar nav a.sibling:hover {
        background: var(--hover);
        text-decoration: none;
      }
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        padding: 0;
        font-size: 1em;
        line-height: 1;
        cursor: pointer;
        color: var(--fg);
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 6px;
      }
      .theme-toggle:hover {
        background: var(--hover);
      }
      .layout {
        display: flex;
        align-items: flex-start;
      }
      /* mobile-only disclosure for the example list. hidden outright on
      desktop, where the sidebar is always open and a focusable-but-invisible
      control would be a keyboard trap */
      .nav-toggle-cb {
        display: none;
      }
      .nav-toggle-label {
        display: none;
      }
      aside.sidebar {
        flex: 0 0 var(--sidebar-width);
        width: var(--sidebar-width);
        position: sticky;
        top: var(--topbar-h);
        align-self: flex-start;
        height: calc(100vh - var(--topbar-h));
        overflow-y: auto;
        border-right: 1px solid var(--border);
        padding: 16px 12px 48px;
      }
      aside.sidebar ul {
        list-style: none;
        margin: 0;
        padding: 0;
      }
      aside.sidebar .nav-group + .nav-group {
        margin-top: 6px;
      }
      aside.sidebar .nav-group-title {
        padding: 10px 8px 3px;
        font-size: 0.7em;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
      }
      aside.sidebar a {
        display: block;
        padding: 2px 8px;
        color: inherit;
        text-decoration: none;
      }
      aside.sidebar a:hover {
        text-decoration: underline;
      }
      aside.sidebar a[aria-current='page'] {
        color: var(--accent);
        font-weight: bold;
      }
      main {
        flex: 1 1 auto;
        min-width: 0;
        margin: 0 auto;
        padding: 24px 16px 80px;
      }
      h1 {
        margin-top: 0;
      }
      /* keep sticky-header-anchored jumps from hiding under the topbar */
      main [id] {
        scroll-margin-top: calc(var(--topbar-h) + 12px);
      }
      /* example-page chrome (ExampleLayout) */
      .lead {
        font-size: 1.05em;
        color: var(--muted);
        max-width: 75ch;
      }
      .doc h2 {
        margin-top: 28px;
        border-bottom: 1px solid var(--rule);
        padding-bottom: 4px;
      }
      .doc p {
        max-width: 75ch;
      }
      .doc h3 {
        margin-top: 20px;
      }
      .doc code {
        background: var(--code-inline-bg);
        padding: 1px 4px;
        border-radius: 3px;
        font-size: 0.9em;
      }
      .doc pre code {
        background: none;
        padding: 0;
      }
      .astro-code {
        position: relative;
        border-radius: 8px;
        padding: 14px 16px;
      }
      /* copy-to-clipboard button injected into every shiki code block */
      .copy-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 3px 8px;
        font-size: 0.75em;
        font-family: inherit;
        color: #cdd3da;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 4px;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.12s;
      }
      .astro-code:hover .copy-btn,
      .copy-btn:focus-visible {
        opacity: 1;
      }
      .copy-btn:hover {
        background: rgba(255, 255, 255, 0.16);
      }
      .demo {
        border: 1px solid var(--border);
        border-radius: 4px;
        margin-bottom: 16px;
      }
      .demo.fill {
        height: 80vh;
        overflow: hidden;
      }
      details.source {
        border: 1px solid var(--border);
        border-radius: 4px;
        margin-bottom: 24px;
      }
      details.source > summary {
        cursor: pointer;
        padding: 8px 12px;
        font-weight: 600;
        user-select: none;
      }
      details.source[open] > summary {
        border-bottom: 1px solid var(--border);
      }
      details.source pre {
        padding: 16px;
        border-radius: 0 0 4px 4px;
        overflow: auto;
        margin: 0;
      }
      /* gallery (index) */
      .intro {
        color: var(--muted);
        margin-top: 0;
        max-width: 70ch;
      }
      .gallery section {
        margin-top: 32px;
      }
      .gallery h2 {
        border-bottom: 1px solid var(--rule);
        padding-bottom: 4px;
      }
      .gallery ul {
        list-style: none;
        padding: 0;
        margin: 12px 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 12px;
      }
      .gallery li a {
        display: block;
        height: 100%;
        padding: 12px 14px;
        border: 1px solid var(--border);
        border-radius: 6px;
        text-decoration: none;
        color: inherit;
      }
      .gallery li a:hover {
        border-color: var(--accent);
        background: var(--card-hover);
      }
      .gallery .title {
        font-weight: 600;
        color: var(--accent);
      }
      .gallery .desc {
        color: var(--muted);
        font-size: 0.9em;
        margin-top: 4px;
      }
      @media (max-width: 820px) {
        .layout {
          display: block;
        }
        /* visually-hidden (not display:none) so the checkbox driving the
        disclosure keeps its place in the tab order — otherwise the menu is
        pointer-only */
        .nav-toggle-cb {
          display: block;
          position: absolute;
          width: 1px;
          height: 1px;
          opacity: 0;
          overflow: hidden;
        }
        .nav-toggle-label {
          display: block;
          margin: 0;
          padding: 10px 16px;
          font-size: 0.9em;
          font-weight: 600;
          color: var(--fg);
          cursor: pointer;
          user-select: none;
          border-bottom: 1px solid var(--border);
        }
        .nav-toggle-cb:focus-visible + .nav-toggle-label {
          outline: 2px solid var(--accent);
          outline-offset: -2px;
        }
        aside.sidebar {
          display: none;
          position: static;
          width: 100%;
          height: auto;
          border-right: none;
          border-bottom: 1px solid var(--border);
        }
        .nav-toggle-cb:checked ~ aside.sidebar {
          display: block;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={base}>
        JBrowse 2 <span>· {componentLabel} examples</span>
      </a>
      <nav>
        <div class="siblings" aria-label="JBrowse embedded components">
          {
            siblings.map(s =>
              isSelf(s.base) ? (
                <span
                  class="sibling current"
                  aria-current="true"
                  title={s.title}
                >
                  {s.label}
                </span>
              ) : (
                <a class="sibling" href={s.base} title={s.title}>
                  {s.label}
                </a>
              ),
            )
          }
        </div>
        <a href={docsHref}>Embedding docs</a>
        <a href="https://jbrowse.org/jb2/">jbrowse.org</a>
        <button
          type="button"
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Toggle dark mode"
        >
          ☾
        </button>
      </nav>
    </header>
    <div class="layout">
      <input type="checkbox" id="nav-toggle" class="nav-toggle-cb" />
      <label class="nav-toggle-label" for="nav-toggle">☰ Examples menu</label>
      <aside class="sidebar">
        <nav aria-label="Examples">
          {
            groups.map(group => (
              <div class="nav-group">
                <div class="nav-group-title">{group}</div>
                <ul>
                  {examples
                    .filter(e => e.group === group)
                    .map(e => (
                      <li>
                        <a
                          href={`${base}${e.slug}/`}
                          aria-current={isActive(e.slug) ? 'page' : undefined}
                        >
                          {e.title}
                        </a>
                      </li>
                    ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>
      <main style={`max-width:${mainMaxWidth}`}>
        <slot />
      </main>
    </div>
    <script is:inline>
      // theme toggle: flip data-theme, remember it, keep the icon in sync
      ;(() => {
        const root = document.documentElement
        const btn = document.getElementById('theme-toggle')
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)')
        const current = () =>
          root.dataset.theme || (prefersDark.matches ? 'dark' : 'light')
        const render = () => {
          btn.textContent = current() === 'dark' ? '☀' : '☾'
        }
        btn.addEventListener('click', () => {
          const next = current() === 'dark' ? 'light' : 'dark'
          root.dataset.theme = next
          localStorage.setItem('jb-theme', next)
          render()
        })
        prefersDark.addEventListener('change', render)
        render()
      })()

      // add a copy button to every shiki code block
      document.querySelectorAll('pre.astro-code').forEach(pre => {
        const code = pre.querySelector('code')
        if (!code) {
          return
        }
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'copy-btn'
        btn.textContent = 'Copy'
        btn.addEventListener('click', async () => {
          await navigator.clipboard.writeText(code.innerText)
          btn.textContent = 'Copied'
          setTimeout(() => {
            btn.textContent = 'Copy'
          }, 1500)
        })
        pre.appendChild(btn)
      })
    </script>
  </body>
</html>
