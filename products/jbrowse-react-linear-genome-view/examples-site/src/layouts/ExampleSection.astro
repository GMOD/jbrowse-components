---
import { Code } from 'astro:components'

import { demoFillHeight } from '../siteMeta.ts'

import type { MarkdownInstance } from 'astro'

// One live demo within an example page: an optional heading (only shown when a
// page stacks several sections), the hand-written doc from src/docs/<slug>.md,
// the live demo (slotted in), and its source. The source is the real, runnable
// file for the demo above, so it's open by default rather than hidden behind a
// collapsed toggle. Section-level descriptions from examples.ts are rendered by
// ExampleLayout's "On this page" card, not here, so the doc carries the prose.
interface Props {
  slug: string
  title?: string
  // pages pass whole section objects via {...section}, so `description` still
  // arrives here. ExampleLayout renders it in the page TOC instead.
  description?: string
  code: string
}

const { slug, title, code } = Astro.props

const docs = import.meta.glob<MarkdownInstance<Record<string, unknown>>>(
  '../docs/*.md',
)
const loader = docs[`../docs/${slug}.md`]
const doc = loader ? await loader() : undefined
const Doc = doc?.Content
---

<section id={slug} class="example-section">
  {title && <h2>{title}</h2>}
  {
    Doc && (
      <div class="doc">
        <Doc />
      </div>
    )
  }
  <div class:list={['demo', { fill: demoFillHeight }]}><slot /></div>
  <details class="source" open>
    <summary>View source</summary>
    <Code code={code} lang="tsx" />
  </details>
</section>
