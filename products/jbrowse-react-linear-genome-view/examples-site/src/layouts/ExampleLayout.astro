---
import { Code } from 'astro:components'

import type { MarkdownInstance } from 'astro'

interface Props {
  slug: string
  title: string
  description?: string
  code: string
}

const { slug, title, description, code } = Astro.props
const base = import.meta.env.BASE_URL

// each example page may have a hand-written doc at src/docs/<slug>.md; render it
// above the live demo when present
const docs = import.meta.glob<MarkdownInstance<Record<string, unknown>>>(
  '../docs/*.md',
)
const loader = docs[`../docs/${slug}.md`]
const doc = loader ? await loader() : undefined
const Doc = doc?.Content
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} — JBrowse Linear Genome View examples</title>
    <style is:global>
      body {
        margin: 0;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica,
          Arial, sans-serif;
        color: #1a1a1a;
        line-height: 1.55;
      }
      header {
        padding: 8px 16px;
        border-bottom: 1px solid #ddd;
        background: #fafafa;
      }
      header a {
        color: #135ba8;
        text-decoration: none;
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 16px 16px 64px;
      }
      h1 {
        margin-top: 0;
      }
      .lead {
        font-size: 1.05em;
        color: #444;
      }
      .doc h2 {
        margin-top: 28px;
        border-bottom: 1px solid #eee;
        padding-bottom: 4px;
      }
      .doc h3 {
        margin-top: 20px;
      }
      .doc a {
        color: #135ba8;
      }
      .doc code {
        background: #f4f4f4;
        padding: 1px 4px;
        border-radius: 3px;
        font-size: 0.9em;
      }
      .doc pre code {
        background: none;
        padding: 0;
      }
      .demo {
        border: 1px solid #ddd;
        border-radius: 4px;
        margin-bottom: 24px;
      }
      pre {
        padding: 16px;
        border-radius: 4px;
        overflow: auto;
      }
    </style>
  </head>
  <body>
    <header><a href={base}>← All examples</a></header>
    <main>
      <h1>{title}</h1>
      {description && <p class="lead">{description}</p>}
      {Doc && <div class="doc"><Doc /></div>}
      <h2>Live demo</h2>
      <div class="demo"><slot /></div>
      <h2>Source</h2>
      <Code code={code} lang="tsx" />
    </main>
  </body>
</html>
