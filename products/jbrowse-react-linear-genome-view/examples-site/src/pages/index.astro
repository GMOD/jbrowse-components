---
import { examples } from '../examples.ts'

const base = import.meta.env.BASE_URL
const groups = [...new Set(examples.map(e => e.group))]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>JBrowse Linear Genome View — examples</title>
    <style is:global>
      body {
        margin: 0;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica,
          Arial, sans-serif;
        color: #1a1a1a;
        background: #fff;
        line-height: 1.5;
      }
      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 24px 16px 64px;
      }
      h1 {
        margin-bottom: 4px;
      }
      .intro {
        color: #555;
        margin-top: 0;
      }
      section {
        margin-top: 32px;
      }
      h2 {
        border-bottom: 1px solid #eee;
        padding-bottom: 4px;
      }
      ul {
        padding-left: 22px;
        margin: 12px 0;
      }
      li {
        margin: 6px 0;
      }
      li a {
        color: #135ba8;
        text-decoration: none;
        font-weight: 600;
      }
      li a:hover {
        text-decoration: underline;
      }
      .desc {
        color: #555;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>JBrowse Linear Genome View</h1>
      <p class="intro">
        Live examples of the <code>@jbrowse/react-linear-genome-view2</code> React
        component. Each page documents one pattern, renders the component, and shows
        its full source.
      </p>
      {
        groups.map(group => (
          <section>
            <h2>{group}</h2>
            <ul>
              {examples
                .filter(e => e.group === group)
                .map(e => (
                  <li>
                    <a href={`${base}${e.slug}/`}>{e.title}</a>
                    <span class="desc"> — {e.description}</span>
                  </li>
                ))}
            </ul>
          </section>
        ))
      }
    </main>
  </body>
</html>
