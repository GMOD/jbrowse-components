---
import Example from "../examples/WithDrawerWidget.tsx"
import code from "../examples/WithDrawerWidget.tsx?raw"
import { pages } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "with-drawer-widget")!
---

<Layout page={page}>
  <Section slug="with-drawer-widget" code={code}>
    <Example client:only="react" />
  </Section>
</Layout>
