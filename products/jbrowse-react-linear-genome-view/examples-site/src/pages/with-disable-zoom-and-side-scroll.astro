---
import Example from '../examples/WithDisableZoomAndSideScroll.tsx'
import code from '../examples/WithDisableZoomAndSideScroll.tsx?raw'
import { examples } from '../examples.ts'
import Layout from '../layouts/ExampleLayout.astro'

const meta = examples.find(e => e.slug === 'with-disable-zoom-and-side-scroll')!
---

<Layout slug={meta.slug} title={meta.title} description={meta.description} code={code}>
  <Example client:only="react" />
</Layout>
