---
import WithInitAdvanced from "../examples/WithInitAdvanced.tsx"
import WithInitAdvancedCode from "../examples/WithInitAdvanced.tsx?raw"
import WithSessionHighlights from "../examples/WithSessionHighlights.tsx"
import WithSessionHighlightsCode from "../examples/WithSessionHighlights.tsx?raw"
import { pages, section } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "session-setup")!
const sec0 = section(page, "with-init-advanced")
const sec1 = section(page, "with-session-highlights")
---

<Layout page={page}>
  <Section {...sec0} code={WithInitAdvancedCode}>
    <WithInitAdvanced client:only="react" />
  </Section>
  <Section {...sec1} code={WithSessionHighlightsCode}>
    <WithSessionHighlights client:only="react" />
  </Section>
</Layout>
