---
import WithInternetAccounts from "../examples/WithInternetAccounts.tsx"
import WithInternetAccountsCode from "../examples/WithInternetAccounts.tsx?raw"
import WithWebWorker from "../examples/WithWebWorker.tsx"
import WithWebWorkerCode from "../examples/WithWebWorker.tsx?raw"
import { pages, section } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "accounts-and-workers")!
const sec0 = section(page, "with-internet-accounts")
const sec1 = section(page, "with-web-worker")
---

<Layout page={page}>
  <Section {...sec0} code={WithInternetAccountsCode}>
    <WithInternetAccounts client:only="react" />
  </Section>
  <Section {...sec1} code={WithWebWorkerCode}>
    <WithWebWorker client:only="react" />
  </Section>
</Layout>
