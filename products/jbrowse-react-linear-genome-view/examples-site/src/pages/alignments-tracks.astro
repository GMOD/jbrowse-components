---
import WithInitAlignmentsDisplay from "../examples/WithInitAlignmentsDisplay.tsx"
import WithInitAlignmentsDisplayCode from "../examples/WithInitAlignmentsDisplay.tsx?raw"
import WithGroupByTag from "../examples/WithGroupByTag.tsx"
import WithGroupByTagCode from "../examples/WithGroupByTag.tsx?raw"
import { pages, section } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "alignments-tracks")!
const sec0 = section(page, "with-init-alignments-display")
const sec1 = section(page, "with-group-by-tag")
---

<Layout page={page}>
  <Section {...sec0} code={WithInitAlignmentsDisplayCode}>
    <WithInitAlignmentsDisplay client:only="react" />
  </Section>
  <Section {...sec1} code={WithGroupByTagCode}>
    <WithGroupByTag client:only="react" />
  </Section>
</Layout>
