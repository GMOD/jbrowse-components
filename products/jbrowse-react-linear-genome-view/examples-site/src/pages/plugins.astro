---
import WithExternalPlugin from '../examples/WithExternalPlugin.tsx'
import WithExternalPluginCode from '../examples/WithExternalPlugin.tsx?raw'
import WithInlinePlugins from '../examples/WithInlinePlugins.tsx'
import WithInlinePluginsCode from '../examples/WithInlinePlugins.tsx?raw'
import WithInternetAccounts from '../examples/WithInternetAccounts.tsx'
import WithInternetAccountsCode from '../examples/WithInternetAccounts.tsx?raw'
import WithWebWorker from '../examples/WithWebWorker.tsx'
import WithWebWorkerCode from '../examples/WithWebWorker.tsx?raw'
import { getPage, section } from '../examples.ts'
import Layout from '../layouts/ExampleLayout.astro'
import Section from '../layouts/ExampleSection.astro'

const page = getPage('plugins')
const sec0 = section(page, 'with-external-plugin')
const sec1 = section(page, 'with-inline-plugins')
const sec2 = section(page, 'with-internet-accounts')
const sec3 = section(page, 'with-web-worker')
---

<Layout page={page}>
  <Section {...sec0} code={WithExternalPluginCode}>
    <WithExternalPlugin client:only="react" />
  </Section>
  <Section {...sec1} code={WithInlinePluginsCode}>
    <WithInlinePlugins client:only="react" />
  </Section>
  <Section {...sec2} code={WithInternetAccountsCode}>
    <WithInternetAccounts client:only="react" />
  </Section>
  <Section {...sec3} code={WithWebWorkerCode}>
    <WithWebWorker client:only="react" />
  </Section>
</Layout>
