{
  "name": "@jbrowse/desktop",
  "version": "4.3.0",
  "type": "module",
  "description": "JBrowse desktop application",
  "license": "Apache-2.0",
  "homepage": "./",
  "author": "JBrowse Team",
  "main": "build/electron.js",
  "dir": "src",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-components.git",
    "directory": "products/jbrowse-desktop"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=development node scripts/start.ts",
    "electron": "electron . --no-sandbox",
    "preelectron": "pnpm build:electron-main",
    "prepack": "pnpm build",
    "build": "cross-env NODE_ENV=production node scripts/build.ts",
    "postbuild": "pnpm build:electron-main",
    "build:electron-main": "node scripts/buildElectronMain.ts",
    "prepackage": "pnpm build",
    "prepackage:linux": "pnpm build",
    "prepackage:mac": "pnpm build",
    "prepackage:win": "pnpm build",
    "prepackage:linux:no-installer": "pnpm build",
    "prepackage:win:no-installer": "pnpm build",
    "package": "node scripts/package.ts",
    "package:linux": "node scripts/package.ts --linux",
    "package:mac": "node scripts/package.ts --mac",
    "package:win": "node scripts/package.ts --win",
    "package:linux:no-installer": "node scripts/package.ts --linux --no-installer",
    "package:win:no-installer": "node scripts/package.ts --win --no-installer",
    "build-electron:linux": "pnpm package:linux && node scripts/publish.ts --linux --publish",
    "build-electron:mac": "pnpm package:mac && node scripts/publish.ts --mac --publish",
    "build-electron:win": "pnpm package:win && node scripts/publish.ts --win --publish",
    "test:e2e": "node test/e2e.ts",
    "test:e2e:headless": "xvfb-run --auto-servernum node test/e2e.ts --headless",
    "test:e2e:build": "pnpm package:linux:no-installer && pnpm test:e2e",
    "test:e2e:ci": "pnpm package:linux:no-installer && pnpm test:e2e:headless",
    "test:e2e:build:win": "pnpm package:win:no-installer && pnpm test:e2e",
    "test:e2e:ci:win": "pnpm package:win:no-installer && pnpm test:e2e:headless",
    "screenshots": "node test/screenshots.ts",
    "screenshots:headless": "xvfb-run --auto-servernum node test/screenshots.ts --headless",
    "screenshots:build": "pnpm package:linux:no-installer && pnpm screenshots:headless"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@fontsource/roboto": "^5.2.10",
    "@gmod/faidx": "^2.0.0",
    "@jbrowse/app-core": "workspace:^",
    "@jbrowse/core": "workspace:^",
    "@jbrowse/mobx-state-tree": "^5.11.1",
    "@jbrowse/plugin-alignments": "workspace:^",
    "@jbrowse/plugin-arc": "workspace:^",
    "@jbrowse/plugin-authentication": "workspace:^",
    "@jbrowse/plugin-bed": "workspace:^",
    "@jbrowse/plugin-breakpoint-split-view": "workspace:^",
    "@jbrowse/plugin-canvas": "workspace:^",
    "@jbrowse/plugin-circular-view": "workspace:^",
    "@jbrowse/plugin-comparative-adapters": "workspace:^",
    "@jbrowse/plugin-config": "workspace:^",
    "@jbrowse/plugin-data-management": "workspace:^",
    "@jbrowse/plugin-dotplot-view": "workspace:^",
    "@jbrowse/plugin-gccontent": "workspace:^",
    "@jbrowse/plugin-gff3": "workspace:^",
    "@jbrowse/plugin-grid-bookmark": "workspace:^",
    "@jbrowse/plugin-gtf": "workspace:^",
    "@jbrowse/plugin-hic": "workspace:^",
    "@jbrowse/plugin-jobs-management": "workspace:^",
    "@jbrowse/plugin-legacy-jbrowse": "workspace:^",
    "@jbrowse/plugin-linear-comparative-view": "workspace:^",
    "@jbrowse/plugin-linear-genome-view": "workspace:^",
    "@jbrowse/plugin-maf": "workspace:^",
    "@jbrowse/plugin-menus": "workspace:^",
    "@jbrowse/plugin-rdf": "workspace:^",
    "@jbrowse/plugin-sequence": "workspace:^",
    "@jbrowse/plugin-spreadsheet-view": "workspace:^",
    "@jbrowse/plugin-sv-inspector": "workspace:^",
    "@jbrowse/plugin-text-indexing": "workspace:^",
    "@jbrowse/plugin-trix": "workspace:^",
    "@jbrowse/plugin-variants": "workspace:^",
    "@jbrowse/plugin-wiggle": "workspace:^",
    "@jbrowse/product-core": "workspace:^",
    "@jbrowse/text-indexing": "workspace:^",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/x-data-grid": "^9.5.0",
    "date-fns": "^4.4.0",
    "deepmerge": "^4.3.1",
    "dockview": "^6.6.1",
    "dockview-react": "^6.6.1",
    "electron-context-menu": "^4.1.2",
    "electron-debug": "^4.1.0",
    "electron-updater": "^6.8.9",
    "mobx": "^6.16.1",
    "mobx-react": "^9.2.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanitize-filename": "^1.6.4"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/packager": "^20.0.1",
    "@types/selenium-webdriver": "^4.35.6",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-chromedriver": "^42.4.0",
    "esbuild": "^0.28.1",
    "selenium-webdriver": "^4.44.0"
  },
  "browserslist": [
    "last 1 chrome version"
  ],
  "private": true
}
