{
  "name": "@jbrowse/react-app2",
  "version": "4.3.0",
  "type": "module",
  "description": "JBrowse 2 app React component",
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "license": "MIT",
  "homepage": "https://jbrowse.org",
  "bugs": "https://github.com/GMOD/jbrowse-components/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-components.git",
    "directory": "products/jbrowse-react-app"
  },
  "author": "JBrowse Team",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./esm/makeWorkerInstance": "./src/makeWorkerInstance.ts",
    "./esm/makeWorkerInstance.js": "./src/makeWorkerInstance.ts",
    "./esm/rpcWorker": "./src/rpcWorker.ts",
    "./esm/rpcWorker.js": "./src/rpcWorker.ts"
  },
  "files": [
    "esm",
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "pnpm run /^build:/",
    "build:css": "node ../../scripts/flattenCss.ts src/styles.css dist/styles.css",
    "build:esm": "node ../../node_modules/typescript7/bin/tsc --build tsconfig.build.esm.json",
    "build:webpack": "webpack -c webpack.config.mjs",
    "clean": "rimraf esm *.tsbuildinfo",
    "prebuild": "pnpm clean",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@jbrowse/app-core": "workspace:^",
    "@jbrowse/core": "workspace:^",
    "@jbrowse/mobx-state-tree": "^5.13.0",
    "@jbrowse/plugin-alignments": "workspace:^",
    "@jbrowse/plugin-arc": "workspace:^",
    "@jbrowse/plugin-authentication": "workspace:^",
    "@jbrowse/plugin-bed": "workspace:^",
    "@jbrowse/plugin-breakpoint-split-view": "workspace:^",
    "@jbrowse/plugin-canvas": "workspace:^",
    "@jbrowse/plugin-circular-view": "workspace:^",
    "@jbrowse/plugin-comparative-adapters": "workspace:^",
    "@jbrowse/plugin-config": "workspace:^",
    "@jbrowse/plugin-data-management": "workspace:^",
    "@jbrowse/plugin-dotplot-view": "workspace:^",
    "@jbrowse/plugin-gccontent": "workspace:^",
    "@jbrowse/plugin-gff3": "workspace:^",
    "@jbrowse/plugin-grid-bookmark": "workspace:^",
    "@jbrowse/plugin-gtf": "workspace:^",
    "@jbrowse/plugin-gwas": "workspace:^",
    "@jbrowse/plugin-hic": "workspace:^",
    "@jbrowse/plugin-legacy-jbrowse": "workspace:^",
    "@jbrowse/plugin-linear-comparative-view": "workspace:^",
    "@jbrowse/plugin-linear-genome-view": "workspace:^",
    "@jbrowse/plugin-maf": "workspace:^",
    "@jbrowse/plugin-menus": "workspace:^",
    "@jbrowse/plugin-rdf": "workspace:^",
    "@jbrowse/plugin-sequence": "workspace:^",
    "@jbrowse/plugin-spreadsheet-view": "workspace:^",
    "@jbrowse/plugin-sv-inspector": "workspace:^",
    "@jbrowse/plugin-trix": "workspace:^",
    "@jbrowse/plugin-variants": "workspace:^",
    "@jbrowse/plugin-wiggle": "workspace:^",
    "@jbrowse/product-core": "workspace:^",
    "@jbrowse/web-core": "workspace:^",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "dockview-react": "^7.0.2",
    "mobx": "^6.16.1",
    "mobx-react": "^9.2.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "esm/index.js",
    "types": "esm/index.d.ts",
    "exports": {
      ".": {
        "types": "./esm/index.d.ts",
        "import": "./esm/index.js"
      },
      "./styles.css": "./dist/styles.css",
      "./esm/makeWorkerInstance": {
        "types": "./esm/makeWorkerInstance.d.ts",
        "import": "./esm/makeWorkerInstance.js"
      },
      "./esm/makeWorkerInstance.js": {
        "types": "./esm/makeWorkerInstance.d.ts",
        "import": "./esm/makeWorkerInstance.js"
      },
      "./esm/rpcWorker": {
        "types": "./esm/rpcWorker.d.ts",
        "import": "./esm/rpcWorker.js"
      },
      "./esm/rpcWorker.js": {
        "types": "./esm/rpcWorker.d.ts",
        "import": "./esm/rpcWorker.js"
      }
    }
  },
  "sideEffects": false
}
