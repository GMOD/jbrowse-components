---
// The stylesheet every consumer of the published package imports — the demos
// below render unstyled dockview tabs without it. Not in the shared
// Shell.astro: that file is symlinked into the lgv/cgv sites, which don't
// depend on react-app2.
import '@jbrowse/react-app2/styles.css'

import Shell from './Shell.astro'
import { examples, type ExamplePage } from '../examples.ts'
import { componentLabel, mainMaxWidth } from '../siteMeta.ts'

// Page-level chrome for an example page. The live demos are supplied as slotted
// <ExampleSection> children so their React islands hydrate in the page file.
// When a page stacks several sections, a "jump to" nav surfaces them up front —
// otherwise the extra demos are only discoverable by scrolling.
interface Props {
  page: ExamplePage
}

const { page } = Astro.props
const multiSection = page.sections.length > 1
---

<Shell
  title={page.title}
  componentLabel={componentLabel}
  examples={examples}
  mainMaxWidth={mainMaxWidth}
>
  <h1>{page.title}</h1>
  <p class="lead">{page.description}</p>
  {
    multiSection && (
      <p>
        On this page:{' '}
        {page.sections.map((s, i) => (
          <>
            {i > 0 && ' · '}
            <a href={`#${s.slug}`}>{s.title}</a>
          </>
        ))}
      </p>
    )
  }
  <slot />
</Shell>
