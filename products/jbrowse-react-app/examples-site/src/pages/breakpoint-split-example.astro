---
import Example from "../examples/BreakpointSplitExample.tsx"
import code from "../examples/BreakpointSplitExample.tsx?raw"
import { pages } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "breakpoint-split-example")!
---

<Layout page={page}>
  <Section slug="breakpoint-split-example" code={code}>
    <Example client:only="react" />
  </Section>
</Layout>
