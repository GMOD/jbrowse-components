---
import Example from "../examples/MultiViewSession.tsx"
import code from "../examples/MultiViewSession.tsx?raw"
import { pages } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "multi-view-session")!
---

<Layout page={page}>
  <Section slug="multi-view-session" code={code}>
    <Example client:only="react" />
  </Section>
</Layout>
