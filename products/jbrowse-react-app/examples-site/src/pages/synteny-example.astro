---
import Layout from "../layouts/ExampleLayout.astro"
import Example from "../examples/SyntenyExample.tsx"
import code from "../examples/SyntenyExample.tsx?raw"
import { examples } from "../examples.ts"

const meta = examples.find(e => e.slug === "synteny-example")!
---

<Layout slug={meta.slug} title={meta.title} description={meta.description} code={code}>
  <Example client:only="react" />
</Layout>
