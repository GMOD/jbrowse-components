---
import Example from "../examples/WithLaunchLinearGenomeView.tsx"
import code from "../examples/WithLaunchLinearGenomeView.tsx?raw"
import { pages } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "with-launch-linear-genome-view")!
---

<Layout page={page}>
  <Section slug="with-launch-linear-genome-view" code={code}>
    <Example client:only="react" />
  </Section>
</Layout>
