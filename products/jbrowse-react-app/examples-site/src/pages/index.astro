---
import { examples } from '../examples.ts'
import Shell from '../layouts/Shell.astro'
import Gallery from '../layouts/Gallery.astro'
import { componentLabel, mainMaxWidth } from '../siteMeta.ts'
---

<Shell
  title="Examples"
  componentLabel={componentLabel}
  examples={examples}
  mainMaxWidth={mainMaxWidth}
>
  <h1>JBrowse React App</h1>
  <p class="intro">
    Live examples of the <code>@jbrowse/react-app2</code> React component — the
    full multi-view JBrowse app embedded in a page. Each page renders the
    component and shows its full source. Browse by category in the sidebar.
  </p>
  <Gallery examples={examples} />
</Shell>
