---
import SyntenyExample from "../examples/SyntenyExample.tsx"
import syntenyCode from "../examples/SyntenyExample.tsx?raw"
import CreateAppSynteny from "../examples/CreateAppSynteny.tsx"
import createAppSyntenyCode from "../examples/CreateAppSynteny.tsx?raw"
import MultiwaySyntenyExample from "../examples/MultiwaySyntenyExample.tsx"
import multiwaySyntenyCode from "../examples/MultiwaySyntenyExample.tsx?raw"
import { pages, section } from "../examples.ts"
import Layout from "../layouts/ExampleLayout.astro"
import Section from "../layouts/ExampleSection.astro"

const page = pages.find(p => p.slug === "synteny-views")!
const synteny = section(page, "synteny-example")
const createAppSection = section(page, "create-app-synteny")
const multiway = section(page, "multiway-synteny-example")
---

<Layout page={page}>
  <Section {...synteny} code={syntenyCode}>
    <SyntenyExample client:only="react" />
  </Section>
  <Section {...createAppSection} code={createAppSyntenyCode}>
    <CreateAppSynteny client:only="react" />
  </Section>
  <Section {...multiway} code={multiwaySyntenyCode}>
    <MultiwaySyntenyExample client:only="react" />
  </Section>
</Layout>
